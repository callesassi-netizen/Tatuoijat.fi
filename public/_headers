# Säkerhetsheaders (Netlify-format — plockas upp automatiskt vid deploy).
# CSP-notis: Astro inlinar små skript (sökformuläret) och vissa styles,
# därför 'unsafe-inline'. Kan skärpas till hashar med Astros
# experimental.csp när sajten stabiliserats.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# Hashade assets kan cachas för evigt (filnamnet byts vid ändring)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable
