---
// Ordbilden "Tatuoijat.fi" (namnet läses från site.name i i18n/ui.ts).
// Brandfärger enligt design-briefen: display-typografi i text-light,
// ingen accentfärg (--flash är reserverad för CTA + aktiva val).
import { useTranslations, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  size?: 'header' | 'footer';
}

const { locale, size = 'header' } = Astro.props;
const t = useTranslations(locale);
---

<span class:list={['logo', `logo--${size}`]}>{t('site.name')}</span>

<style>
  .logo {
    font-family: var(--font-display);
    letter-spacing: 0.06em;
    color: var(--text-light);
  }
  .logo--header {
    font-size: 17px;
  }
  .logo--footer {
    font-size: 20px;
  }
  @media (min-width: 1024px) {
    .logo--header {
      font-size: 20px;
    }
    .logo--footer {
      font-size: 22px;
    }
  }
</style>
