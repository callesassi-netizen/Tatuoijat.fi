---
// Ordbilden "Tatuoijat.fi" som bild (vit blackletter-typografi, transparent
// bakgrund) — fungerar på alla mörka ytor (header, footer, hero). Ett enda
// raster i tillräcklig upplösning för den största visningskontexten (hero
// desktop); mindre kontexter skalas ner via CSS height, vilket alltid är
// skarpt (nedskalning tappar aldrig kvalitet som uppskalning gör).
import { Image } from 'astro:assets';
import logoSrc from '../assets/bilder/tatuoijat-logo.png';
import { useTranslations, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  size?: 'header' | 'footer' | 'hero';
}

const { locale, size = 'header' } = Astro.props;
const t = useTranslations(locale);
---

<Image
  class:list={['logo', `logo--${size}`]}
  src={logoSrc}
  alt={t('site.name')}
  width={900}
  loading={size === 'hero' ? 'eager' : 'lazy'}
  fetchpriority={size === 'hero' ? 'high' : undefined}
/>

<style>
  .logo {
    display: block;
    width: auto;
    height: 20px;
  }
  .logo--footer {
    height: 24px;
  }
  .logo--hero {
    height: 82px;
  }
  @media (min-width: 1024px) {
    .logo--header {
      height: 24px;
    }
    .logo--footer {
      height: 30px;
    }
    .logo--hero {
      height: 190px;
    }
  }
</style>
