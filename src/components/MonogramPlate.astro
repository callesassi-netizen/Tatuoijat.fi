---
/**
 * Monogram-/mönsterplatta för profiler utan egna bilder (Bildpolicy §2).
 * Genereras deterministiskt från namnet: initialer i Archivo Black på
 * bläcksvart botten med ett subtilt mönster i brand-tonerna.
 * Default-läget dag 1 — får ALDRIG se trasigt ut.
 */
interface Props {
  name: string;
}

const { name } = Astro.props;

const words = name.trim().split(/\s+/);
const initials =
  words.length >= 2
    ? (words[0]![0]! + words[words.length - 1]![0]!).toUpperCase()
    : name.slice(0, 2).toUpperCase();

// Deterministisk variation per namn
const hash = [...name].reduce((acc, ch) => (acc * 31 + ch.charCodeAt(0)) >>> 0, 7);
const patterns = ['lines', 'dots', 'arcs', 'grid'] as const;
const pattern = patterns[hash % patterns.length];
const backgrounds = ['#101014', '#15151b', '#1a191f'] as const;
const bg = backgrounds[hash % backgrounds.length];
const patternId = `mp-${pattern}-${hash % 997}`;
---

<svg
  class="monogram-plate"
  viewBox="0 0 320 320"
  preserveAspectRatio="xMidYMid slice"
  role="img"
  aria-label={name}
>
  <defs>
    {
      pattern === 'lines' && (
        <pattern id={patternId} width="14" height="14" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
          <line x1="0" y1="0" x2="0" y2="14" stroke="#F6F2EA" stroke-width="1" />
        </pattern>
      )
    }
    {
      pattern === 'dots' && (
        <pattern id={patternId} width="18" height="18" patternUnits="userSpaceOnUse">
          <circle cx="4" cy="4" r="1.4" fill="#F6F2EA" />
        </pattern>
      )
    }
    {
      pattern === 'arcs' && (
        <pattern id={patternId} width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M0 40 A40 40 0 0 1 40 0" fill="none" stroke="#F6F2EA" stroke-width="1" />
        </pattern>
      )
    }
    {
      pattern === 'grid' && (
        <pattern id={patternId} width="22" height="22" patternUnits="userSpaceOnUse">
          <path d="M22 0H0V22" fill="none" stroke="#F6F2EA" stroke-width="1" />
        </pattern>
      )
    }
  </defs>
  <rect width="320" height="320" fill={bg}></rect>
  <rect width="320" height="320" fill={`url(#${patternId})`} opacity="0.07"></rect>
  <circle cx="160" cy="160" r="92" fill={bg} stroke="#F6F2EA" stroke-opacity="0.18" stroke-width="1.5"></circle>
  <text
    x="160"
    y="160"
    text-anchor="middle"
    dominant-baseline="central"
    fill="#EDEAE2"
    font-size="76"
    letter-spacing="2">{initials}</text
  >
</svg>

<style>
  .monogram-plate {
    width: 100%;
    height: 100%;
    display: block;
  }
  .monogram-plate text {
    font-family: var(--font-display);
  }
</style>
