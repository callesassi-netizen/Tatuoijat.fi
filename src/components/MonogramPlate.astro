---
/**
 * Monogram-/mönsterplatta för profiler utan egna bilder (Bildpolicy §2).
 * Genereras deterministiskt från namnet: initialer i Archivo Black på
 * bläck-gradient med ett subtilt mönster i brand-tonerna.
 * Featured: guldring runt monogram-cirkeln + dotwork-textur.
 * Default-läget dag 1 — får ALDRIG se trasigt ut.
 */
interface Props {
  name: string;
  featured?: boolean;
}

const { name, featured = false } = Astro.props;

const words = name.trim().split(/\s+/);
const initials =
  words.length >= 2
    ? (words[0]![0]! + words[words.length - 1]![0]!).toUpperCase()
    : name.slice(0, 2).toUpperCase();

// Deterministisk variation per namn
const hash = [...name].reduce((acc, ch) => (acc * 31 + ch.charCodeAt(0)) >>> 0, 7);
const patterns = ['lines', 'dots', 'arcs', 'grid'] as const;
const pattern = patterns[hash % patterns.length];

// Bläck-gradienter i olika valörer (#1c1c22 → #4d3230-spannet)
const inkStops = [
  ['#1c1c22', '#33262a'],
  ['#201e27', '#3c2b2b'],
  ['#23202a', '#452f2e'],
] as const;
const [inkFrom, inkTo] = inkStops[hash % inkStops.length]!;
const uid = `mp${hash % 9973}`;
---

<svg
  class="monogram-plate"
  viewBox="0 0 320 320"
  preserveAspectRatio="xMidYMid slice"
  role="img"
  aria-label={name}
>
  <defs>
    <linearGradient id={`${uid}-bg`} x1="0" y1="0" x2="0.7" y2="1">
      <stop offset="0" stop-color={inkFrom}></stop>
      <stop offset="1" stop-color={inkTo}></stop>
    </linearGradient>
    {
      pattern === 'lines' && (
        <pattern id={`${uid}-p`} width="14" height="14" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
          <line x1="0" y1="0" x2="0" y2="14" stroke="#F6F2EA" stroke-width="1" />
        </pattern>
      )
    }
    {
      pattern === 'dots' && (
        <pattern id={`${uid}-p`} width="18" height="18" patternUnits="userSpaceOnUse">
          <circle cx="4" cy="4" r="1.4" fill="#F6F2EA" />
        </pattern>
      )
    }
    {
      pattern === 'arcs' && (
        <pattern id={`${uid}-p`} width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M0 40 A40 40 0 0 1 40 0" fill="none" stroke="#F6F2EA" stroke-width="1" />
        </pattern>
      )
    }
    {
      pattern === 'grid' && (
        <pattern id={`${uid}-p`} width="22" height="22" patternUnits="userSpaceOnUse">
          <path d="M22 0H0V22" fill="none" stroke="#F6F2EA" stroke-width="1" />
        </pattern>
      )
    }
    {
      featured && (
        <pattern id={`${uid}-dot`} width="11" height="11" patternUnits="userSpaceOnUse">
          <circle cx="2.5" cy="2.5" r="0.9" fill="#F6F2EA" />
        </pattern>
      )
    }
  </defs>
  <rect width="320" height="320" fill={`url(#${uid}-bg)`}></rect>
  <rect width="320" height="320" fill={`url(#${uid}-p)`} opacity="0.07"></rect>
  {/* Subtil dotwork-textur på featured-kortens mörka yta */}
  {featured && <rect width="320" height="320" fill={`url(#${uid}-dot)`} opacity="0.05"></rect>}
  <circle
    cx="160"
    cy="160"
    r="92"
    fill={inkFrom}
    stroke={featured ? '#C9A227' : '#F6F2EA'}
    stroke-opacity={featured ? '0.85' : '0.18'}
    stroke-width={featured ? '2' : '1.5'}
  ></circle>
  {featured && <circle cx="160" cy="160" r="86" fill="none" stroke="#C9A227" stroke-opacity="0.25" stroke-width="1"></circle>}
  <text
    x="160"
    y="160"
    text-anchor="middle"
    dominant-baseline="central"
    fill="#EDEAE2"
    font-size="76"
    letter-spacing="2">{initials}</text
  >
</svg>

<style>
  .monogram-plate {
    width: 100%;
    height: 100%;
    display: block;
  }
  .monogram-plate text {
    font-family: var(--font-display);
  }
</style>
