---
/**
 * Sök: stad + stil + röd CTA i ett flytande vitt kort med skugga som
 * ligger ÖVER skarven mellan mörk hero och benvitt ark (wireframe 1b/2b).
 * Mobil: fälten staplade. Desktop: enrads layout inne i samma kort.
 * Navigeringen sker med en liten inline-ö. Utan JS fungerar chips-
 * och stadskorts-länkarna.
 */
import type { CollectionEntry } from 'astro:content';
import { useTranslations, localePath, type Locale } from '../i18n/ui';
import { cityDisplayName, styleDisplayName } from '../lib/content';

interface Props {
  locale: Locale;
  cities: CollectionEntry<'cities'>[];
  styles: CollectionEntry<'styles'>[];
  selectedCity?: string;
  /** Unikt prefix om komponenten renderas flera gånger på samma sida. */
  idPrefix: string;
  popularCities?: CollectionEntry<'cities'>[];
  /** Label före chipsen (default "Suosittua:"). */
  chipsLabel?: string;
  /** Stads-slug som markeras som aktiv (röd) chip. */
  activeCityChip?: string;
}

const {
  locale,
  cities,
  styles,
  selectedCity = '',
  idPrefix,
  popularCities = [],
  chipsLabel,
  activeCityChip = '',
} = Astro.props;

const t = useTranslations(locale);
const basePath = localePath(locale, '/');
const chipsLabelText = chipsLabel ?? t('search.popular');
// Dropdownen alfabetisk — lättare att hitta sin stad i en lång lista
const citiesAlpha = [...cities].sort((a, b) =>
  cityDisplayName(a, locale).localeCompare(cityDisplayName(b, locale), locale),
);
---

<div class="search">
  <form data-search data-base={basePath} action={localePath(locale, '/tatuoijat/')} method="get">
    <div class="fields">
      <div class="field">
        <label for={`${idPrefix}-city`}>{t('search.city')}</label>
        <select id={`${idPrefix}-city`} name="kaupunki">
          <option value="" selected={selectedCity === ''}>{t('search.allCities')}</option>
          {
            citiesAlpha.map((city) => (
              <option value={city.id} selected={city.id === selectedCity}>
                {cityDisplayName(city, locale)}
              </option>
            ))
          }
        </select>
        <span class="caret" aria-hidden="true">▾</span>
      </div>
      <div class="divider" aria-hidden="true"></div>
      <div class="field">
        <label for={`${idPrefix}-style`}>{t('search.style')}</label>
        <select id={`${idPrefix}-style`} name="tyyli">
          <option value="" selected>{t('search.allStyles')}</option>
          {
            styles.map((style) => (
              <option value={style.id}>{styleDisplayName(style, locale)}</option>
            ))
          }
        </select>
        <span class="caret" aria-hidden="true">▾</span>
      </div>
    </div>
    <button class="btn-cta search-cta" type="submit">{t('search.cta')}</button>
  </form>
  {
    popularCities.length > 0 && (
      <p class="popular">
        <span class="popular-label">{chipsLabelText}</span>
        {popularCities.map((city) => (
          <a
            class:list={['chip', { 'chip--active': city.id === activeCityChip }]}
            href={localePath(locale, `/tatuoijat/${city.id}/`)}
            aria-current={city.id === activeCityChip ? 'page' : undefined}
          >
            {cityDisplayName(city, locale)}
          </a>
        ))}
      </p>
    )
  }
</div>

<script>
  // Bygger URL:en /tatuoijat/{stad}/?tyyli={stil} av formulärvalen.
  document.querySelectorAll<HTMLFormElement>('form[data-search]').forEach((form) => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const base = (form.dataset.base ?? '/').replace(/\/$/, '');
      const city = (form.elements.namedItem('kaupunki') as HTMLSelectElement).value;
      const style = (form.elements.namedItem('tyyli') as HTMLSelectElement).value;
      let url = city ? `${base}/tatuoijat/${city}/` : `${base}/tatuoijat/`;
      if (style) url += `?tyyli=${encodeURIComponent(style)}`;
      window.location.href = url;
    });
  });
</script>

<style>
  /* Det flytande kortet — enda ytan på sajten med skugga */
  form {
    background: var(--surface);
    border-radius: var(--r-float);
    box-shadow: var(--shadow-float);
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .fields {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .field {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1px;
    background: var(--paper);
    border: var(--card-border-strong);
    border-radius: var(--r-btn);
    padding: 10px 14px;
  }
  .field label {
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--meta);
  }
  .field select {
    appearance: none;
    -webkit-appearance: none;
    border: 0;
    background: transparent;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    padding: 0 18px 0 0;
    cursor: pointer;
  }
  .field select:focus-visible {
    outline: 2px solid var(--flash);
    outline-offset: 2px;
    border-radius: 4px;
  }
  .caret {
    position: absolute;
    right: 14px;
    top: 50%;
    translate: 0 -50%;
    color: var(--meta);
    font-size: 12px;
    pointer-events: none;
  }
  .divider {
    display: none;
  }

  .popular {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    margin: 12px 4px 0;
  }
  .popular-label {
    font-size: 11px;
    font-weight: 500;
    color: var(--meta);
  }

  /* Desktop: enrads layout inne i samma flytande kort */
  @media (min-width: 1024px) {
    form {
      flex-direction: row;
      align-items: stretch;
      padding: 12px;
      gap: 12px;
    }
    .fields {
      flex: 1;
      flex-direction: row;
      gap: 0;
      background: var(--paper);
      border: var(--card-border-strong);
      border-radius: var(--r-btn);
    }
    .field {
      flex: 1;
      background: none;
      border: 0;
      padding: 12px 18px;
    }
    .field:first-child {
      flex: 1.1;
    }
    .field select {
      font-size: 14.5px;
    }
    .divider {
      display: block;
      width: 1px;
      background: rgba(16, 16, 20, 0.12);
      margin: 10px 0;
    }
    .search-cta {
      width: auto;
      padding: 0 30px;
      display: flex;
      align-items: center;
    }
    .popular {
      margin-top: 14px;
    }
    .popular-label {
      font-size: 12px;
    }
  }
</style>
