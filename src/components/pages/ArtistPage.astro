---
/**
 * Studioprofil (wireframe 3a mobil / 3e desktop): mörk identitets-hero,
 * flytande kontaktkort över skarven, portfolio som kärna, artisterna på
 * studion (med personliga IG-länkar), Tietoa och Luotettavuus.
 * Desktop: kontaktkort + info i höger sidopanel (340 px).
 * Utan bilder (Bildpolicy §2): monogram-platta + tydlig Instagram-länk —
 * får aldrig se trasigt ut. Kortets bild morphar hit via View Transition.
 */
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MonogramPlate from '../MonogramPlate.astro';
import InstagramEmbed from '../InstagramEmbed.astro';
import { useTranslations, localePath, type Locale } from '../../i18n/ui';
import {
  getCitiesSorted,
  getStylesSorted,
  getStudioArtists,
  isFeatured,
  isPaid,
  isVerified,
  localizedBody,
  cityDisplayName,
  styleDisplayName,
} from '../../lib/content';
import { pricing } from '../../data/pricing';
import { jsonLdString, breadcrumbLd, tattooParlorLd } from '../../lib/schema';
import { citiesIndexPath, cityPath } from '../../lib/routes';

interface Props {
  studio: CollectionEntry<'studios'>;
  locale: Locale;
}

const { studio, locale } = Astro.props;
const t = useTranslations(locale);
const p = (path: string) => localePath(locale, path);
const site = Astro.site!;
const { data } = studio;

const cities = await getCitiesSorted();
const styles = await getStylesSorted();
const city = data.city ? cities.find((entry) => entry.id === data.city) : undefined;
const cityName = city ? cityDisplayName(city, locale) : undefined;
const h1City = city && locale === 'fi' ? city.data.nameLocative : cityName;
// Utan matchande stadssida: visa seedens plats/region — aldrig tomt
const displayPlace = cityName ?? data.place ?? t('common.finland');

const styleNames = data.styles.map((slug) => {
  const style = styles.find((entry) => entry.id === slug);
  return style ? styleDisplayName(style, locale) : slug;
});

const bio = localizedBody(studio.body, locale);
const placeLine = [data.district, displayPlace].filter(Boolean).join(', ');

// Artisterna (personerna) på studion. Ensam artist med samma namn som
// studion döljs i visningslistan — hens IG är redan studions kontaktväg —
// men räknas ändå med i embed-aggregeringen nedan (allStudioArtists).
const igUrl = (handle: string) => `https://instagram.com/${handle}`;
const allStudioArtists = await getStudioArtists(studio.id);
const persons = allStudioArtists.filter((person) => person.data.name !== data.name);
// Handle-only-artister (non-FTAA) — visas som @-chips; dubbletter mot
// personer och studions egen handle filtreras bort
const personHandles = new Set(
  persons.map((person) => person.data.instagram).filter(Boolean),
);
const extraHandles = data.artistInstagrams.filter(
  (handle) => !personHandles.has(handle) && handle !== data.instagram,
);
const hasArtistsSection = persons.length > 0 || extraHandles.length > 0;

// Nivåhärledning (matris): featured = premium, betald = pro|premium.
const paid = isPaid(studio);
const featured = isFeatured(studio);
const verified = isVerified(studio);
const claim = pricing[locale].claim;

const instagramUrl = data.instagram ? igUrl(data.instagram) : undefined;
// Cookiefri kartlänk (ingen embed/JS/cookies → noll CWV-kostnad): öppnar
// adressen i användarens kart-app. Endast när adress finns (annars dölj).
const mapHref = data.address
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(data.address)}`
  : undefined;
// Boka-tid-knapp ENDAST för betald nivå (matris: minimal kontakt på perus).
// Extern bokning först, annars studions hemsida.
const bookingHref = paid ? (data.bookingUrl ?? data.website ?? undefined) : undefined;
const phoneHref = paid && data.phone ? `tel:${data.phone.replace(/\s+/g, '')}` : undefined;
// Kontaktkortet visas när det finns något att visa (boka/tel/IG) eller när
// betald nivå får det cookiefria Netlify-kontaktformuläret.
const hasContact = Boolean(bookingHref || phoneHref || instagramUrl || paid);
const worksCount = data.images.length;
// Riktiga bilder vinner (Bildpolicy §2-tillstånd); annars max 2
// Instagram-embeds (handoff §8) — studions egna poster först, sedan
// artisternas (många multi-artist-studios saknar egen instagram-handle
// och har bara poster via sina artister); annars dagens monogram+IG-knapp.
const allEmbedPosts = [
  ...data.instagram_posts,
  ...allStudioArtists.flatMap((person) => person.data.instagram_posts),
];
const embedPosts = data.images.length === 0 ? allEmbedPosts.slice(0, 2) : [];
const displayWorksCount = data.images.length > 0 ? data.images.length : embedPosts.length;

const path = `/artistit/${studio.id}/`;
// Studionamn upp till 40 tecken finns i datan — faller tillbaka på kort
// mall så att titeln aldrig passerar 60 tecken (SERP-trunkering).
const fullTitle = t('artist.metaTitle', { name: data.name, city: displayPlace, site: t('site.name') });
const title = fullTitle.length <= 60
  ? fullTitle
  : t('artist.metaTitleShort', { name: data.name, site: t('site.name') });
const description = bio
  ? bio.length > 155
    ? `${bio.slice(0, 152)}…`
    : bio
  : t('artist.metaDescriptionFallback', {
      name: data.name,
      place: displayPlace,
      site: t('site.name'),
    });

const breadcrumbItems = [{ name: t('breadcrumb.home'), url: new URL(p('/'), site).href }];
if (city && h1City) {
  breadcrumbItems.push({
    name: t('city.h1', { city: h1City }),
    url: new URL(p(cityPath(city, locale)), site).href,
  });
}
breadcrumbItems.push({ name: data.name, url: new URL(p(path), site).href });
const breadcrumb = breadcrumbLd(breadcrumbItems);
const parlor = tattooParlorLd(studio, displayPlace, new URL(p(path), site).href);
---

<BaseLayout title={title} description={description} locale={locale} path={path} hasAlternate>
  <script type="application/ld+json" set:html={jsonLdString(breadcrumb)} slot="head" />
  <script type="application/ld+json" set:html={jsonLdString(parlor)} slot="head" />

  <!-- Mörk identitets-hero -->
  <section class="artist-hero">
    <div class="container artist-hero-inner">
      {
        city && h1City ? (
          <a class="back-link ink-link" href={p(cityPath(city, locale))}>
            ← {t('city.h1', { city: h1City })}
          </a>
        ) : (
          <a class="back-link ink-link" href={p(citiesIndexPath(locale))}>← {t('nav.cities')}</a>
        )
      }
      {
        featured && (
          <p class="badge-row">
            <span class="badge-featured">★ {t('card.featured')}</span>
          </p>
        )
      }
      <h1 class="artist-name">{data.name}</h1>
      {placeLine && <p class="artist-place">{placeLine}</p>}
      {
        styleNames.length > 0 && (
          <p class="artist-chips">
            {styleNames.map((styleName) => (
              <span class="chip chip--dark">{styleName}</span>
            ))}
          </p>
        )
      }
    </div>
  </section>

  <!-- Ark: kontaktkort över skarven, portfolio, info -->
  <div class="sheet grain">
    <div class="container layout">
      <aside class="side">
        {
          /* Kontaktkortet renderas bara när det finns riktiga länkar —
             en död CTA ser trasig ut. Utan kontakt flyter trust-kortet
             över skarven i stället. */
          hasContact && (
            <div class="contact-card">
              {bookingHref && (
                <a class="btn-cta" href={bookingHref} target="_blank" rel="noopener noreferrer">
                  {t('artist.book')}
                </a>
              )}
              {phoneHref && (
                <a class="btn-outline contact-phone" href={phoneHref}>
                  {t('artist.call')} · {data.phone}
                </a>
              )}
              {instagramUrl && (
                <a class="btn-outline" href={instagramUrl} target="_blank" rel="noopener noreferrer">
                  Instagram · @{data.instagram}
                </a>
              )}
              {paid && data.hours && (
                <p class="contact-hours">
                  <span class="contact-hours-label">{t('artist.hours')}</span>
                  {data.hours}
                </p>
              )}
              {
                /* Cookiefri Netlify-kontaktknapp (matris: Pro/Premium). Formuläret
                   detekteras vid build via data-netlify; honeypot mot spam, ingen
                   reCAPTCHA/cookie. Fältet `studio` skiljer inläggen åt. */
                paid && (
                  <details class="contact-form-toggle">
                    <summary class="btn-outline contact-form-summary">
                      {t('artist.contact.cta')}
                    </summary>
                    <form
                      class="contact-form"
                      name="yhteydenotto"
                      method="POST"
                      data-netlify="true"
                      netlify-honeypot="bot-field"
                      action={p(path)}
                    >
                      <input type="hidden" name="form-name" value="yhteydenotto" />
                      <input type="hidden" name="studio" value={data.name} />
                      <p class="hp" aria-hidden="true">
                        <label>Bot field <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
                      </p>
                      <label class="cf-label" for="cf-name">{t('artist.contact.name')}</label>
                      <input id="cf-name" name="nimi" type="text" required autocomplete="name" />
                      <label class="cf-label" for="cf-email">{t('artist.contact.email')}</label>
                      <input id="cf-email" name="sahkoposti" type="email" required autocomplete="email" />
                      <label class="cf-label" for="cf-msg">{t('artist.contact.message')}</label>
                      <textarea id="cf-msg" name="viesti" rows="3" required />
                      <button class="btn-cta cf-submit" type="submit">{t('artist.contact.submit')}</button>
                    </form>
                  </details>
                )
              }
              <p class="contact-note">{t('artist.responds')}</p>
            </div>
          )
        }

        <div class:list={['trust-card', { 'trust-card--float': !hasContact }]}>
          <h2 class="trust-title">{t('artist.trust')}</h2>
          {
            verified && (
              <p class="trust-row">
                <span class="trust-check" aria-hidden="true">✓</span>
                {t('artist.verified')}
              </p>
            )
          }
          {
            data.ftaaMember && (
              <p class="trust-row">
                <span class="trust-check" aria-hidden="true">✓</span>
                {t('artist.ftaa')}
              </p>
            )
          }
          {
            data.walkIn && (
              <p class="trust-row">
                <span class="trust-check" aria-hidden="true">✓</span>
                {t('artist.walkin')}
              </p>
            )
          }
          {
            data.website && (
              <p class="trust-row">
                <span class="trust-check" aria-hidden="true">✓</span>
                <a class="ink-link" href={data.website} target="_blank" rel="noopener noreferrer">{t('artist.website')}</a>
              </p>
            )
          }
          <div class="trust-studio">
            <span class="trust-studio-name">{data.name}</span>
            <span class="trust-studio-address">
              {data.address ? data.address : displayPlace}
            </span>
            {
              mapHref && (
                <a
                  class="trust-map ink-link"
                  href={mapHref}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span class="trust-map-pin" aria-hidden="true">◈</span>
                  {t('artist.map')}
                </a>
              )
            }
          </div>
        </div>

        {
          /* Diskret claim-loop på gratisprofiler (matris): leder till /hinnasto. */
          !paid && (
            <a class="claim-cta" href={p('/hinnasto/')}>
              <span class="claim-q">{claim.question}</span>
              <span class="claim-link">{claim.cta} →</span>
            </a>
          )
        }
      </aside>

      <div class="main-col">
        <!-- Portfolio: kärnan -->
        <section class="portfolio" aria-labelledby="portfolio-title">
          <div class="portfolio-head">
            <h2 class="portfolio-title" id="portfolio-title">{t('artist.portfolio')}</h2>
            {
              displayWorksCount > 0 && (
                <span class="portfolio-count">
                  {displayWorksCount === 1
                    ? t('artist.works.one')
                    : t('artist.works.many', { n: displayWorksCount })}
                </span>
              )
            }
          </div>
          {
            worksCount > 0 ? (
              <div class="portfolio-grid">
                {data.images.map((image, index) => (
                  <div
                    class="portfolio-item"
                    style={index === 0 ? `view-transition-name: artist-image-${studio.id};` : undefined}
                  >
                    <img src={image} alt={`${data.name} — ${index + 1}`} loading={index < 2 ? 'eager' : 'lazy'} />
                  </div>
                ))}
              </div>
            ) : embedPosts.length > 0 ? (
              <div class="portfolio-embeds">
                {embedPosts.map((url, index) => (
                  <div
                    class="portfolio-item"
                    style={index === 0 ? `view-transition-name: artist-image-${studio.id};` : undefined}
                  >
                    <InstagramEmbed url={url} name={data.name} locale={locale} />
                  </div>
                ))}
              </div>
            ) : (
              <div class="portfolio-empty">
                <div class="portfolio-plate" style={`view-transition-name: artist-image-${studio.id};`}>
                  <MonogramPlate name={data.name} featured={featured} />
                </div>
                <div class="portfolio-empty-info">
                  <h3 class="portfolio-empty-title">{t('artist.noImages.title')}</h3>
                  <p class="portfolio-empty-text">{t('artist.noImages.text')}</p>
                  {
                    instagramUrl && (
                      <a class="btn-outline portfolio-empty-cta" href={instagramUrl} target="_blank" rel="noopener noreferrer">
                        {t('artist.igCtaStudio', { name: data.name })}
                      </a>
                    )
                  }
                </div>
              </div>
            )
          }
        </section>

        <!-- Tietoa -->
        {
          bio && (
            <section class="about" aria-labelledby="about-title">
              <h2 class="about-title" id="about-title">{t('artist.about')}</h2>
              <p class="about-text">{bio}</p>
            </section>
          )
        }

        <!-- Artisterna på studion, med personliga IG-länkar -->
        {
          hasArtistsSection && (
            <section class="about" aria-labelledby="artists-title">
              <h2 class="about-title" id="artists-title">{t('artist.artists')}</h2>
              <p class="studio-artists">
                {persons.map((person) =>
                  person.data.instagram ? (
                    <a class="chip" href={igUrl(person.data.instagram)} target="_blank" rel="noopener noreferrer">
                      {person.data.name}
                      <span class="chip-ig" aria-hidden="true">↗</span>
                    </a>
                  ) : (
                    <span class="chip">{person.data.name}</span>
                  ),
                )}
                {extraHandles.map((handle) => (
                  <a class="chip" href={igUrl(handle)} target="_blank" rel="noopener noreferrer">
                    @{handle}
                    <span class="chip-ig" aria-hidden="true">↗</span>
                  </a>
                ))}
              </p>
            </section>
          )
        }
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .artist-hero {
    position: relative;
    z-index: 0;
    background: var(--ink);
  }
  .artist-hero-inner {
    padding: 20px var(--page-pad) 64px;
  }
  .back-link {
    font-size: 11px;
    font-weight: 600;
    color: var(--meta);
  }
  .badge-row {
    margin: 18px 0 8px;
  }
  .artist-name {
    font-size: 36px;
    line-height: 1.04;
    color: var(--text-light);
    margin-top: 8px;
  }
  .badge-row + .artist-name {
    margin-top: 0;
  }
  .artist-place {
    margin: 8px 0 0;
    font-size: 13.5px;
    color: var(--meta);
  }
  .artist-chips {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin: 14px 0 0;
  }

  .sheet {
    position: relative;
    z-index: 1;
    background: var(--paper);
    border-radius: var(--r-sheet) var(--r-sheet) 0 0;
    margin-top: -24px;
  }
  .layout {
    padding: 0 var(--page-pad) 40px;
  }

  /* Flytande kontaktkort — samma skugga som sökkortet */
  .contact-card {
    position: relative;
    margin-top: -38px;
    background: var(--surface);
    border-radius: var(--r-float);
    box-shadow: var(--shadow-float);
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .contact-note {
    font-size: 11.5px;
    color: var(--meta);
    text-align: center;
    margin: 0;
  }
  .contact-hours {
    font-size: 12px;
    color: var(--text);
    margin: 2px 0;
    text-align: center;
  }
  .contact-hours-label {
    display: block;
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--meta);
    margin-bottom: 2px;
  }

  /* Netlify-kontaktformulär (Pro/Premium) — vikt bakom en knapp så kortet
     är kompakt tills besökaren väljer att ta kontakt. */
  .contact-form-toggle {
    margin: 0;
  }
  .contact-form-summary {
    list-style: none;
    display: block;
    width: 100%;
    text-align: center;
    cursor: pointer;
  }
  .contact-form-summary::-webkit-details-marker {
    display: none;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 12px;
  }
  .cf-label {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--meta);
    margin-top: 4px;
  }
  .contact-form input,
  .contact-form textarea {
    font-family: var(--font-body);
    /* 16px så iOS inte zoomar in vid fokus */
    font-size: 16px;
    color: var(--text);
    background: var(--paper);
    border: var(--card-border-strong);
    border-radius: var(--r-btn);
    padding: 10px 12px;
    width: 100%;
    resize: vertical;
  }
  .contact-form input:focus-visible,
  .contact-form textarea:focus-visible {
    outline: 2px solid var(--flash);
    outline-offset: 1px;
  }
  .cf-submit {
    margin-top: 8px;
  }
  .hp {
    position: absolute;
    left: -9999px;
    margin: 0;
  }

  /* Diskret claim-CTA på gratisprofiler → /hinnasto (konverteringsslingan) */
  .claim-cta {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin-top: 14px;
    padding: 14px 16px;
    background: var(--surface);
    border: 1px dashed var(--border-on-paper);
    border-radius: var(--r-card);
    text-decoration: none;
    transition:
      border-color var(--t-med) var(--ease-out),
      background-color var(--t-med) var(--ease-out);
  }
  .claim-cta:hover {
    border-color: var(--flash);
    background: var(--paper);
  }
  .claim-q {
    font-size: 12.5px;
    color: var(--text);
  }
  .claim-link {
    font-size: 12.5px;
    font-weight: 700;
    color: var(--flash);
  }

  .portfolio {
    margin-top: 28px;
  }
  .portfolio-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .portfolio-title {
    font-size: 25px;
    color: var(--text);
  }
  .portfolio-count {
    font-size: 12px;
    color: var(--meta);
  }
  .portfolio-grid {
    columns: 2;
    column-gap: 10px;
  }
  .portfolio-item {
    break-inside: avoid;
    margin-bottom: 10px;
    border-radius: 10px;
    overflow: hidden;
    background: var(--ink);
  }

  /* Instagram-embeds får INTE ligga i multikolumn: Meta tvingar min-width
     326px på sin iframe, så smala columns-spalter (~162px på mobil) klipper
     embedden på mitten. Grid med minmax(min(326px,100%),1fr) ger en full
     spalt på mobil (≥326px, ingen klippning) och 1–2 spalter på desktop —
     aldrig smalare än IG kräver. */
  .portfolio-embeds {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(326px, 100%), 1fr));
    gap: 12px;
  }
  .portfolio-embeds .portfolio-item {
    margin-bottom: 0;
  }
  .portfolio-item img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Utan bilder: monogram-platta + IG-länk — aldrig "trasigt" */
  .portfolio-empty {
    background: var(--surface);
    border: var(--card-border);
    border-radius: var(--r-card-lg);
    overflow: hidden;
  }
  .portfolio-plate {
    height: 240px;
  }
  .portfolio-empty-info {
    padding: 18px;
    text-align: center;
  }
  .portfolio-empty-title {
    font-size: 16px;
    color: var(--text);
    margin: 0;
  }
  .portfolio-empty-text {
    font-size: 13px;
    line-height: 1.5;
    color: var(--meta);
    max-width: 340px;
    margin: 8px auto 14px;
  }
  .portfolio-empty-cta {
    display: inline-block;
    width: auto;
    padding: 12px 22px;
  }

  .about {
    margin-top: 32px;
  }
  .about-title {
    font-size: 18px;
    color: var(--text);
    margin-bottom: 8px;
  }
  .about-text {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text);
    margin: 0;
    max-width: 620px;
  }

  .trust-card {
    margin-top: 26px;
    background: var(--surface);
    border: var(--card-border);
    border-radius: var(--r-card);
    padding: 16px;
  }
  /* Utan kontaktkort tar trust-kortet dess plats över skarven */
  .trust-card--float {
    margin-top: -38px;
    border: 0;
    border-radius: var(--r-float);
    box-shadow: var(--shadow-float);
  }
  .studio-artists {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin: 0;
  }
  .chip-ig {
    font-size: 10px;
    margin-left: 4px;
    opacity: 0.6;
  }
  .trust-title {
    font-size: 15px;
    color: var(--text);
    margin-bottom: 12px;
  }
  .trust-row {
    display: flex;
    gap: 9px;
    align-items: baseline;
    font-size: 13px;
    color: var(--text);
    margin: 0 0 9px;
  }
  .trust-check {
    font-weight: 700;
    font-size: 12px;
  }
  .trust-studio {
    margin-top: 14px;
    padding-top: 12px;
    border-top: var(--card-border);
  }
  .trust-studio-name {
    display: block;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--text);
  }
