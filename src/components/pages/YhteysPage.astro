---
/**
 * /yhteys — allmän kontaktsida med rättelse-/borttagningsbegäran (CLAUDE.md,
 * juridik). Renderar det DELADE formuläret (ContactForm, Netlify name="liity")
 * — samma form som /liity, inget separat Netlify-formulär. Indexerbar
 * (trust-/E-E-A-T-sida), länkad i footern.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, localePath, type Locale } from '../../i18n/ui';
import { getCitiesSorted } from '../../lib/content';
import { jsonLdString, breadcrumbLd } from '../../lib/schema';
import ContactForm from '../ContactForm.astro';
import { yhteys } from '../../data/yhteys';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const p = (path: string) => localePath(locale, path);
const site = Astro.site!;
const c = yhteys[locale];
const cities = await getCitiesSorted();

const path = '/yhteys/';
const breadcrumb = breadcrumbLd([
  { name: t('breadcrumb.home'), url: new URL(p('/'), site).href },
  { name: c.h1, url: new URL(p(path), site).href },
]);
---

<BaseLayout
  title={c.metaTitle}
  description={c.metaDescription}
  locale={locale}
  path={path}
  hasAlternate
>
  <script type="application/ld+json" set:html={jsonLdString(breadcrumb)} slot="head" />

  <section class="yht-hero">
    <div class="container yht-hero-inner">
      <p class="eyebrow">{c.eyebrow}</p>
      <h1 class="yht-title">{c.h1}</h1>
      <p class="yht-intro">{c.intro}</p>
    </div>
  </section>

  <div class="sheet grain">
    <div class="container sheet-inner">
      <section class="form-col" aria-labelledby="yht-form-title">
        <h2 class="col-title" id="yht-form-title">{c.formTitle}</h2>
        <ContactForm locale={locale} cities={cities} action={p('/yhteys/')} defaultReason="kysymys" />
      </section>

      <!-- Rättelse-/borttagningsnotis (juridik) -->
      <aside class="removal" aria-labelledby="yht-removal-title">
        <h2 class="removal-title" id="yht-removal-title">{c.removalTitle}</h2>
        <p class="removal-text">{c.removalText}</p>
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .yht-hero {
    position: relative;
    z-index: 0;
    background:
      radial-gradient(110% 100% at 80% 0%, rgba(77, 50, 48, 0.2) 0%, rgba(16, 16, 20, 0) 55%),
      var(--ink);
  }
  .yht-hero-inner {
    padding: 40px var(--page-pad) 56px;
  }
  .yht-title {
    font-size: 42px;
    line-height: 1.02;
    color: var(--text-light);
  }
  .yht-intro {
    margin: 12px 0 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--meta);
    max-width: 480px;
  }

  .sheet {
    position: relative;
    z-index: 1;
    background: var(--paper);
    border-radius: var(--r-sheet) var(--r-sheet) 0 0;
    margin-top: -20px;
  }
  .sheet-inner {
    padding: 30px var(--page-pad) 48px;
    max-width: 640px;
    margin-inline: auto;
  }

  .col-title {
    font-size: 22px;
    color: var(--text);
    margin-bottom: 16px;
  }

  .removal {
    margin-top: 28px;
    background: var(--surface);
    border: var(--card-border);
    border-radius: var(--r-card-lg);
    padding: 20px;
  }
  .removal-title {
    font-size: 15px;
    color: var(--text);
    margin: 0 0 8px;
  }
  .removal-text {
    font-size: 13px;
    line-height: 1.6;
    color: var(--meta);
    margin: 0;
  }

  @media (min-width: 1024px) {
    .yht-hero-inner {
      padding: 64px var(--page-pad) 84px;
    }
    .yht-title {
      font-size: 64px;
    }
    .yht-intro {
      font-size: 16px;
      max-width: 560px;
    }
    .sheet {
      margin-top: -26px;
    }
    .sheet-inner {
      padding: 48px var(--page-pad) 72px;
    }
    .col-title {
      font-size: 30px;
      margin-bottom: 20px;
    }
    .removal {
      margin-top: 36px;
      padding: 24px;
    }
  }
</style>
