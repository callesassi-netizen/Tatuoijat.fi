---
/**
 * Städer-index (/tatuoijat/) — delad mellan fi och sv.
 * Två nivåer: de största städerna som kort med stor siffra,
 * därunder ALLA städer som kompakt alfabetisk katalog-lista
 * (46 likadana kort i en ändlös grid skalade inte).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, localePath, type Locale } from '../../i18n/ui';
import { getCitiesSorted, studioCountByCity, cityDisplayName } from '../../lib/content';
import { breadcrumbLd } from '../../lib/schema';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const p = (path: string) => localePath(locale, path);
const site = Astro.site!;
const cities = await getCitiesSorted();
const counts = await studioCountByCity();
const title = `${t('nav.cities')} — ${t('site.tagline')} | ${t('site.name')}`;

// Topp 9 efter antal (3×3-grid), resten i den kompakta listan
const byCount = [...cities].sort(
  (a, b) =>
    (counts.get(b.id) ?? 0) - (counts.get(a.id) ?? 0) ||
    cityDisplayName(a, locale).localeCompare(cityDisplayName(b, locale), locale),
);
const topCities = byCount.slice(0, 9);
const topIds = new Set(topCities.map((city) => city.id));
const alphabetical = [...cities].sort((a, b) =>
  cityDisplayName(a, locale).localeCompare(cityDisplayName(b, locale), locale),
);

const breadcrumb = breadcrumbLd([
  { name: t('breadcrumb.home'), url: new URL(p('/'), site).href },
  { name: t('nav.cities'), url: new URL(p('/tatuoijat/'), site).href },
]);
---

<BaseLayout
  title={title}
  description={t('site.description')}
  locale={locale}
  path="/tatuoijat/"
  hasAlternate
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} slot="head" />
  <section class="index-hero">
    <div class="container index-hero-inner">
      <p class="eyebrow">{t('home.cities.eyebrow')}</p>
      <h1 class="index-title">{t('home.cities.title')}</h1>
    </div>
  </section>
  <div class="sheet grain">
    <div class="container sheet-inner">
      <!-- Nivå 1: de största städerna -->
      <section aria-labelledby="top-cities-title">
        <h2 class="tier-title" id="top-cities-title">{t('cities.top.title')}</h2>
        <div class="city-grid">
          {
            topCities.map((city) => {
              const count = counts.get(city.id) ?? 0;
              return (
                <a class="city-card" href={p(`/tatuoijat/${city.id}/`)}>
                  <span class="city-name">
                    {cityDisplayName(city, locale)}
                    <span class="city-arrow" aria-hidden="true">→</span>
                  </span>
                  {count > 0 && (
                    <span class="city-count">
                      <span class="city-num" aria-hidden="true">{count}</span>
                      <span class="visually-hidden">
                        {count === 1
                          ? t('home.artistCount.one')
                          : t('home.artistCount.many', { n: count })}
                      </span>
                    </span>
                  )}
                </a>
              );
            })
          }
        </div>
      </section>

      <!-- Nivå 2: kompakt katalog A–Ö -->
      <section class="all-cities" aria-labelledby="all-cities-title">
        <h2 class="tier-title" id="all-cities-title">{t('cities.all.title')}</h2>
        <ul class="city-list">
          {
            alphabetical.map((city) => {
              const count = counts.get(city.id) ?? 0;
              return (
                <li>
                  <a
                    class:list={['city-link', { 'city-link--top': topIds.has(city.id) }]}
                    href={p(`/tatuoijat/${city.id}/`)}
                  >
                    <span class="city-link-name ink-link">{cityDisplayName(city, locale)}</span>
                    {count > 0 && <span class="city-link-count">{count}</span>}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .index-hero {
    position: relative;
    z-index: 0;
    background: var(--ink);
  }
  .index-hero-inner {
    padding: 28px var(--page-pad) 46px;
  }
  .index-title {
    font-size: 34px;
    line-height: 1.06;
    color: var(--text-light);
  }
  .sheet {
    position: relative;
    z-index: 1;
    background: var(--paper);
    border-radius: var(--r-sheet) var(--r-sheet) 0 0;
    margin-top: var(--sheet-overlap);
  }
  .sheet-inner {
    padding: 26px var(--page-pad) 44px;
  }
  .tier-title {
    font-size: 18px;
    color: var(--text);
    margin-bottom: 14px;
  }

  .city-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .city-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    background: var(--surface);
    border: var(--card-border-strong);
    border-radius: var(--r-card);
    padding: 16px;
    text-decoration: none;
    transition:
      transform var(--t-med) var(--ease-out),
      box-shadow var(--t-med) var(--ease-out);
  }
  .city-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(16, 16, 20, 0.12);
  }
  .city-name {
    position: relative;
    display: inline-block;
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--text);
  }
  .city-name::after {
    content: '';
    position: absolute;
    left: 0;
    right: 16px;
    bottom: -3px;
    height: 2px;
    background: var(--text);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--t-med) var(--ease-out);
  }
  .city-card:hover .city-name::after {
    transform: scaleX(1);
  }
  .city-arrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 13px;
    margin-left: 6px;
    opacity: 0;
    transform: translateX(-6px);
    transition:
      transform var(--t-med) var(--ease-out),
      opacity var(--t-med) var(--ease-out);
  }
  .city-card:hover .city-arrow {
    opacity: 1;
    transform: translateX(0);
  }
  .city-num {
    font-family: var(--font-display);
    font-variant-numeric: tabular-nums;
    font-size: 26px;
    color: var(--border-on-paper);
    transition: color var(--t-med) ease-out;
  }
  .city-card:hover .city-num {
    color: var(--meta);
  }

  /* Kompakt A–Ö-katalog */
  .all-cities {
    margin-top: 38px;
  }
  .city-list {
    list-style: none;
    margin: 0;
    padding: 0;
    columns: 2;
    column-gap: 28px;
  }
  .city-list li {
    break-inside: avoid;
  }
  .city-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding: 8px 0;
    text-decoration: none;
    border-bottom: 1px solid rgba(16, 16, 20, 0.07);
  }
  .city-link-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
  }
  .city-link--top .city-link-name {
    font-weight: 700;
  }
  .city-link:hover .city-link-name::after {
    transform: scaleX(1);
  }
  .city-link-count {
    font-size: 12px;
    font-variant-numeric: tabular-nums;
    color: var(--meta);
  }

  @media (min-width: 1024px) {
    .index-hero-inner {
      padding: 44px var(--page-pad) 64px;
    }
    .index-title {
      font-size: 52px;
    }
    .sheet-inner {
      padding: 44px var(--page-pad) 64px;
    }
    .tier-title {
      font-size: 24px;
      margin-bottom: 18px;
    }
    .city-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }
    .city-card {
      padding: 20px;
    }
    .city-name {
      font-size: 17px;
    }
    .city-num {
      font-size: 34px;
    }
    .all-cities {
      margin-top: 56px;
    }
    .city-list {
      columns: 4;
      column-gap: 40px;
    }
  }
</style>
