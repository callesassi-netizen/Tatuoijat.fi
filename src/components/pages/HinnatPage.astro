---
/**
 * Prisguiden /hinnat — SEO-magneten. Long-form med hintataulukko,
 * prisfaktorer och FAQ (FAQPage-schema enligt CLAUDE.md).
 */
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, localePath, type Locale } from '../../i18n/ui';
import { hinnat } from '../../data/hinnat';
import { jsonLdString, breadcrumbLd, faqLd } from '../../lib/schema';
import { citiesIndexPath } from '../../lib/routes';
import heroImage from '../../assets/bilder/jalkihoito.png';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const p = (path: string) => localePath(locale, path);
const site = Astro.site!;
const c = hinnat[locale];

const path = '/hinnat/';
const breadcrumb = breadcrumbLd([
  { name: t('breadcrumb.home'), url: new URL(p('/'), site).href },
  { name: c.h1, url: new URL(p(path), site).href },
]);
const faq = faqLd(c.faq);
---

<BaseLayout
  title={c.metaTitle}
  description={c.metaDescription}
  locale={locale}
  path={path}
  hasAlternate
>
  <script type="application/ld+json" set:html={jsonLdString(breadcrumb)} slot="head" />
  <script type="application/ld+json" set:html={jsonLdString(faq)} slot="head" />

  <section class="guide-hero">
    <div class="container guide-hero-inner">
      <div>
        <p class="eyebrow">{c.eyebrow}</p>
        <h1 class="guide-title">{c.h1}</h1>
      </div>
      <div class="guide-hero-media" aria-hidden="true">
        <Image
          src={heroImage}
          alt=""
          widths={[500, 900]}
          sizes="(min-width: 1024px) 38vw, 100vw"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <div class="sheet grain">
    <div class="container sheet-inner">
      <div class="prose-col">
        {c.intro.map((paragraph) => <p class="lead">{paragraph}</p>)}

        <!-- Hintataulukko -->
        <section aria-labelledby="table-title" class="block">
          <h2 class="block-title" id="table-title">{c.tableTitle}</h2>
          <div class="table-card">
            <table>
              <thead>
                <tr>{c.tableColumns.map((column) => <th scope="col">{column}</th>)}</tr>
              </thead>
              <tbody>
                {
                  c.rows.map((row) => (
                    <tr>
                      <th scope="row">{row.label}</th>
                      <td>{row.size}</td>
                      <td class="price">{row.price}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
          <p class="table-note">{c.tableNote}</p>
        </section>

        <!-- Prisfaktorer -->
        <section aria-labelledby="factors-title" class="block">
          <h2 class="block-title" id="factors-title">{c.factorsTitle}</h2>
          <div class="factors">
            {
              c.factors.map((factor, index) => (
                <div class="factor">
                  <span class="factor-number" aria-hidden="true">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                  <div>
                    <h3 class="factor-title">{factor.title}</h3>
                    <p class="factor-text">{factor.text}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </section>

        <!-- FAQ -->
        <section aria-labelledby="faq-title" class="block">
          <h2 class="block-title" id="faq-title">{c.faqTitle}</h2>
          <div class="faq-list">
            {
              c.faq.map((item) => (
                <details class="faq-item">
                  <summary>
                    <span class="faq-q">{item.q}</span>
                    <span class="faq-icon" aria-hidden="true">+</span>
                  </summary>
                  <p class="faq-a">{item.a}</p>
                </details>
              ))
            }
          </div>
        </section>

        <!-- CTA -->
        <section class="cta-block">
          <h2 class="cta-title">{c.ctaTitle}</h2>
          <p class="cta-text">{c.ctaText}</p>
          <a class="btn-cta cta-btn" href={p(citiesIndexPath(locale))}>{c.ctaLabel}</a>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .guide-hero {
    position: relative;
    z-index: 0;
    background: var(--ink);
  }
  .guide-hero-inner {
    padding: 28px var(--page-pad) 52px;
  }
  .guide-hero-media {
    margin-top: 20px;
    border-radius: var(--r-card);
    overflow: hidden;
  }
  .guide-hero-media :global(img) {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
    filter: saturate(0.9);
  }
  .guide-title {
    font-size: 36px;
    line-height: 1.04;
    color: var(--text-light);
    max-width: 560px;
  }

  .sheet {
    position: relative;
    z-index: 1;
    background: var(--paper);
    border-radius: var(--r-sheet) var(--r-sheet) 0 0;
    margin-top: -20px;
  }
  .sheet-inner {
    padding: 28px var(--page-pad) 48px;
  }
  .prose-col {
    max-width: 720px;
  }
  .lead {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text);
    margin: 0 0 14px;
  }

  .block {
    margin-top: 40px;
  }
  .block-title {
    font-size: 22px;
    color: var(--text);
    margin-bottom: 16px;
  }

  .table-card {
    background: var(--surface);
    border: var(--card-border);
    border-radius: var(--r-card);
    overflow-x: auto;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13.5px;
  }
  thead th {
    text-align: left;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--meta);
    padding: 14px 16px 10px;
    border-bottom: var(--card-border);
  }
  tbody th,
  tbody td {
    text-align: left;
    padding: 12px 16px;
    border-bottom: var(--card-border);
    color: var(--text);
    font-weight: 400;
  }
  tbody tr:last-child th,
  tbody tr:last-child td {
    border-bottom: 0;
  }
  tbody th {
    font-weight: 600;
    white-space: nowrap;
  }
  tbody td:nth-child(2) {
    color: var(--meta);
  }
  .price {
    font-family: var(--font-display);
    font-size: 13px;
    white-space: nowrap;
  }
  .table-note {
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--meta);
    margin: 12px 2px 0;
  }

  .factors {
    display: grid;
    gap: 18px;
  }
  .factor {
    display: flex;
    gap: 14px;
  }
  .factor-number {
    font-family: var(--font-display);
    font-size: 22px;
    line-height: 1.1;
    color: var(--border-on-paper);
  }
  .factor-title {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    margin: 0;
  }
  .factor-text {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--meta);
    margin: 4px 0 0;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .faq-item {
    background: var(--surface);
    border: var(--card-border);
    border-radius: var(--r-card);
    padding: 0 16px;
  }
  .faq-item summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 15px 0;
    cursor: pointer;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-q {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
  }
  .faq-icon {
    font-size: 18px;
    color: var(--meta);
    transition: transform var(--t-fast) ease-out;
  }
  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
  }
  .faq-a {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text);
    margin: 0;
    padding: 0 0 16px;
  }

  .cta-block {
    margin-top: 48px;
    background: var(--ink);
    border-radius: var(--r-card-lg);
    padding: 26px 22px;
    text-align: center;
  }
  .cta-title {
    font-size: 22px;
    color: var(--text-light);
  }
  .cta-text {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--meta);
    max-width: 380px;
    margin: 8px auto 18px;
  }
  .cta-btn {
    display: inline-block;
    width: auto;
    padding: 14px 30px;
  }

  @media (min-width: 1024px) {
    .guide-hero-inner {
      padding: 44px var(--page-pad) 76px;
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 48px;
      align-items: center;
    }
    .guide-hero-media {
      margin-top: 0;
      border-radius: var(--r-card-lg);
    }
    .guide-hero-media :global(img) {
      height: 260px;
    }
    .guide-title {
      font-size: 64px;
    }
    .sheet {
      margin-top: -26px;
    }
    .sheet-inner {
      padding: 44px var(--page-pad) 64px;
    }
    .lead {
      font-size: 16px;
    }
    .block {
      margin-top: 56px;
    }
    .block-title {
      font-size: 30px;
      margin-bottom: 20px;
    }
    table {
      font-size: 14.5px;
    }
    .factors {
      grid-template-columns: 1fr 1fr;
      gap: 24px 32px;
    }
    .cta-block {
      padding: 40px;
    }
    .cta-title {
      font-size: 30px;
    }
  }
</style>
