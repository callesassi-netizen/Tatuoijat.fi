---
/**
 * /hinnasto — B2B-säljsidan för studios. Tre priskort (Perus/Pro/Premium)
 * + full jämförelsetabell, byggd HELT ur src/data/pricing.ts (delad källa
 * med det bantade /liity). CTA per betald nivå → Stripe Payment Link.
 *
 * OBS: helt skild från /hinnat (konsument-SEO: "vad kostar en tatuering").
 * Länka ALDRIG ihop dem — annan målgrupp, annan sökintention.
 */
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, localePath, type Locale } from '../../i18n/ui';
import {
  pricing,
  priceLabel,
  TIER_ORDER,
  TIER_PRICE,
  STRIPE_LINKS,
  PAYMENTS_LIVE,
  type Tier,
} from '../../data/pricing';
import { jsonLdString, breadcrumbLd, faqLd } from '../../lib/schema';
import heroImage from '../../assets/bilder/studio-vaalea.png';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const p = (path: string) => localePath(locale, path);
const site = Astro.site!;
const c = pricing[locale];

const path = '/hinnasto/';
const breadcrumb = breadcrumbLd([
  { name: t('breadcrumb.home'), url: new URL(p('/'), site).href },
  { name: c.h1, url: new URL(p(path), site).href },
]);
const faq = faqLd(c.faq);

// Alla nivåer startar en ansökan (/liity, vald nivå via ?taso=) så länge
// betalning är manuell. När PAYMENTS_LIVE=true går betalda kort till Stripe.
const ctaHref = (tier: Tier): string =>
  tier !== 'perus' && PAYMENTS_LIVE ? STRIPE_LINKS[tier] : p(`/liity/?taso=${tier}#ilmoittaudu`);
const ctaExternal = (tier: Tier): boolean => tier !== 'perus' && PAYMENTS_LIVE;

const cellClass = (v: boolean | string): string =>
  v === true ? 'cell cell--yes' : v === false ? 'cell cell--no' : 'cell cell--text';
---

<BaseLayout
  title={c.metaTitle}
  description={c.metaDescription}
  locale={locale}
  path={path}
  hasAlternate
>
  <script type="application/ld+json" set:html={jsonLdString(breadcrumb)} slot="head" />
  <script type="application/ld+json" set:html={jsonLdString(faq)} slot="head" />

  <!-- Mörk hero -->
  <section class="hin-hero">
    <div class="container hin-hero-inner">
      <div class="hin-hero-copy">
        <p class="eyebrow">{c.eyebrow}</p>
        <h1 class="hin-title">{c.h1}</h1>
        <p class="hin-intro">{c.intro}</p>
      </div>
      <div class="hin-hero-media" aria-hidden="true">
        <Image
          src={heroImage}
          alt=""
          widths={[500, 900]}
          sizes="(min-width: 1024px) 40vw, 100vw"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <div class="sheet grain">
    <div class="container sheet-inner">
      <!-- Tre priskort -->
      <div class="plans">
        {
          TIER_ORDER.map((tier) => {
            const plan = c.tiers[tier];
            const isPremium = tier === 'premium';
            const isPro = tier === 'pro';
            return (
              <div class:list={['plan', `plan--${tier}`, { 'plan--highlight': isPro }]}>
                {isPremium && (
                  <p class="plan-badge"><span class="badge-featured">★ {t('card.featured')}</span></p>
                )}
                {isPro && <p class="plan-flag">{c.popularLabel}</p>}
                <h2 class="plan-name">{plan.name}</h2>
                <p class="plan-tagline">{plan.tagline}</p>
                <p class="plan-price">
                  <span class="plan-amount">{priceLabel(tier)}</span>
                  {TIER_PRICE[tier] > 0 && <span class="plan-period">{plan.period}</span>}
                </p>
                <ul class="plan-features">
                  {plan.features.map((feature) => (
                    <li>
                      <span class:list={['check', { 'check--gold': isPremium }]} aria-hidden="true">✓</span>
                      {feature}
                    </li>
                  ))}
                </ul>
                {ctaExternal(tier) ? (
                  <a
                    class:list={[isPremium || isPro ? 'btn-cta' : 'btn-outline', 'plan-cta']}
                    href={ctaHref(tier)}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {plan.cta}
                  </a>
                ) : (
                  <a class="btn-outline plan-cta" href={ctaHref(tier)}>{plan.cta}</a>
                )}
                {plan.ctaNote && <p class="plan-cta-note">{plan.ctaNote}</p>}
              </div>
            );
          })
        }
      </div>

      <!-- Benefit-/teaser-sektion: konkreta nyttor, diskret kopplade till
           rätt nivå. Sanningsenligt — inga obelagda superlativ. -->
      <section class="benefits" aria-labelledby="benefits-title">
        <h2 class="compare-title" id="benefits-title">{c.benefits.title}</h2>
        <div class="benefit-grid">
          {
            c.benefits.items.map((benefit) => (
              <div class="benefit-card">
                {benefit.tier && (
                  <span class:list={['benefit-tier', `benefit-tier--${benefit.tier}`]}>
                    {c.tiers[benefit.tier].name}
                  </span>
                )}
                <h3 class="benefit-title">{benefit.title}</h3>
                <p class="benefit-text">{benefit.text}</p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Full jämförelsetabell -->
      <section class="compare" aria-labelledby="compare-title">
        <h2 class="compare-title" id="compare-title">{c.matrixTitle}</h2>
        <div class="table-card">
          <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th scope="col">{c.matrixFeatureHead}</th>
                {TIER_ORDER.map((tier) => (
                  <th scope="col" class:list={{ 'col--premium': tier === 'premium' }}>
                    {c.tiers[tier].name}
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {
                c.matrix.map((row) => (
                  <tr>
                    <th scope="row">{row.label}</th>
                    {(['perus', 'pro', 'premium'] as Tier[]).map((tier) => {
                      const v = row[tier];
                      return (
                        <td
                          class:list={[cellClass(v), { 'cell-premium': tier === 'premium' }]}
                          data-tier={c.tiers[tier].name}
                        >
                          {v === true ? (
                            <>
                              <span aria-hidden="true">✓</span>
                              <span class="visually-hidden">{c.yes}</span>
                            </>
                          ) : v === false ? (
                            <>
                              <span aria-hidden="true">—</span>
                              <span class="visually-hidden">{c.no}</span>
                            </>
                          ) : (
                            v
                          )}
                        </td>
                      );
                    })}
                  </tr>
                ))
              }
            </tbody>
          </table>
          </div>
        </div>
      </section>

      <!-- FAQ (FAQPage-schema i head) -->
      <section class="faq" aria-labelledby="hin-faq-title">
        <h2 class="compare-title" id="hin-faq-title">{c.faqTitle}</h2>
        <div class="faq-list">
          {
            c.faq.map((item) => (
              <details class="faq-item">
                <summary>
                  <span class="faq-q">{item.q}</span>
                  <span class="faq-icon" aria-hidden="true">+</span>
                </summary>
                <p class="faq-a">{item.a}</p>
              </details>
            ))
          }
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .hin-hero {
    position: relative;
    z-index: 0;
    background:
      radial-gradient(110% 100% at 80% 0%, rgba(77, 50, 48, 0.2) 0%, rgba(16, 16, 20, 0) 55%),
      var(--ink);
  }
  .hin-hero-inner {
    padding: 28px var(--page-pad) 56px;
  }
  .hin-hero-media {
    margin-top: 22px;
    border-radius: var(--r-card);
    overflow: hidden;
  }
  .hin-hero-media :global(img) {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    filter: saturate(0.9);
  }
  .hin-title {
    font-size: 42px;
    line-height: 1.02;
    color: var(--text-light);
  }
  .hin-intro {
    margin: 12px 0 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--meta);
    max-width: 440px;
  }

  .sheet {
    position: relative;
    z-index: 1;
    background: var(--paper);
    border-radius: var(--r-sheet) var(--r-sheet) 0 0;
    margin-top: -20px;
  }
  .sheet-inner {
    padding: 30px var(--page-pad) 48px;
  }

  /* ── Priskort ── */
  .plans {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 1040px;
    margin-inline: auto;
  }
  .plan {
    position: relative;
    border-radius: var(--r-card-lg);
    padding: 24px;
    display: flex;
    flex-direction: column;
  }
  .plan--perus {
    background: var(--surface);
    border: var(--card-border);
  }
  .plan--pro {
    background: var(--surface);
    border: 2px solid var(--flash);
  }
  .plan--premium {
    background: var(--ink);
    color: var(--text-light);
  }
  .plan-flag {
    position: absolute;
    top: -11px;
    left: 24px;
    margin: 0;
    background: var(--flash);
    color: #fff;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: var(--r-chip);
  }
  .plan-badge {
    margin: 0 0 12px;
  }
  .plan-name {
    font-size: 24px;
    color: inherit;
  }
  .plan-tagline {
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--meta);
    margin: 6px 0 0;
  }
  .plan--premium .plan-tagline {
    color: rgba(237, 234, 226, 0.7);
  }
  .plan-price {
    margin: 16px 0 18px;
  }
  .plan-amount {
    font-family: var(--font-display);
    font-size: 34px;
    color: inherit;
  }
  .plan-period {
    font-size: 13px;
    color: var(--meta);
    margin-left: 4px;
  }
  .plan-features {
    list-style: none;
    margin: 0 0 22px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .plan-features li {
    display: flex;
    gap: 9px;
    align-items: baseline;
    font-size: 13.5px;
    line-height: 1.5;
  }
  .plan--premium .plan-features li {
    color: var(--text-light);
  }
  .check {
    font-weight: 700;
    font-size: 12px;
    color: var(--flash);
  }
  .check--gold {
    color: var(--gold);
  }
  .plan-cta {
    width: 100%;
  }
  .plan--premium :global(.btn-outline) {
    color: var(--text-light);
    border-color: rgba(237, 234, 226, 0.35);
  }
  .plan-cta-note {
    font-size: 11.5px;
    color: var(--meta);
    text-align: center;
    margin: 10px 0 0;
  }

  /* ── Benefit-/teaser-sektion ── */
  .benefits {
    margin-top: 48px;
  }
  .benefit-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .benefit-card {
    background: var(--surface);
    border: var(--card-border);
    border-radius: var(--r-card);
    padding: 20px;
  }
  .benefit-tier {
    display: inline-block;
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 9px;
    border-radius: var(--r-chip);
    margin-bottom: 11px;
  }
  .benefit-tier--pro {
    color: var(--flash);
    border: 1px solid var(--flash);
  }
  .benefit-tier--premium {
    color: var(--gold);
    border: 1px solid rgba(201, 162, 39, 0.5);
  }
  .benefit-title {
    font-family: var(--font-display);
    font-size: 16px;
    line-height: 1.28;
    color: var(--text);
    margin: 0;
  }
  .benefit-text {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--meta);
    margin: 7px 0 0;
  }

  /* ── Jämförelsetabell ── */
  .compare {
    margin-top: 48px;
  }
  .compare-title {
    font-size: 22px;
    color: var(--text);
    margin-bottom: 16px;
  }
  .table-card {
    border: var(--card-border);
    border-radius: var(--r-card-lg);
    overflow: hidden;
    background: var(--surface);
  }
  .table-scroll {
    overflow-x: auto;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    min-width: 520px;
  }
  thead th {
    padding: 16px;
    background: var(--paper);
    border-bottom: 2px solid var(--border-on-paper);
    white-space: nowrap;
  }
  thead th:first-child {
    text-align: left;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--meta);
  }
  thead th:not(:first-child) {
    text-align: center;
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--text);
  }
  thead th.col--premium {
    color: var(--gold);
    box-shadow: inset 0 3px 0 0 var(--gold);
  }
  tbody th {
    text-align: left;
    font-weight: 600;
    color: var(--text);
    padding: 13px 16px;
  }
  tbody td {
    text-align: center;
    width: 22%;
    padding: 13px 16px;
    color: var(--text);
    font-size: 12.5px;
  }
  tbody tr + tr th,
  tbody tr + tr td {
    border-top: var(--card-border);
  }
  tbody tr:hover th,
  tbody tr:hover td {
    background-color: rgba(16, 16, 20, 0.02);
  }

  /* Premium-kolumnen lyfts som en varm pelare (matchar priskortets guld) */
  thead th.col--premium,
  tbody td.cell-premium {
    background: rgba(201, 162, 39, 0.09);
  }
  tbody tr:hover td.cell-premium {
    background-color: rgba(201, 162, 39, 0.15);
  }

  /* ✓ = fylld cirkel (guld i Premium-kolumnen), — = dämpat streck */
  .cell--yes span[aria-hidden='true'] {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--paper);
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
  }
  .cell-premium.cell--yes span[aria-hidden='true'] {
    background: var(--gold);
    color: var(--ink);
  }
  .cell--no {
    color: var(--border-on-paper);
    font-size: 15px;
  }
  .cell--text {
    color: var(--meta);
  }
  .cell-premium.cell--text {
    color: var(--text);
    font-weight: 500;
  }

  /* ── Mobil: stapla tabellen till kort (ingen horisontell scroll) ──
     Varje funktionsrad blir ett kort: funktionsnamn som rubrik, därunder
     de tre nivåerna som "Nivå — värde"-rader. data-tier ger nivånamnet. */
  @media (max-width: 640px) {
    .table-card {
      background: transparent;
      border: 0;
      overflow: visible;
    }
    .table-scroll {
      overflow-x: visible;
    }
    table {
      min-width: 0;
    }
    thead {
      /* kolumnrubrikerna ersätts av data-tier per cell */
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
    }
    tbody,
    tbody tr,
    tbody th,
    tbody td {
      display: block;
    }
    tbody tr {
      background: var(--surface);
      border: var(--card-border);
      border-radius: var(--r-card);
      padding: 14px 16px;
      margin-bottom: 10px;
    }
    tbody th {
      padding: 0 0 10px;
      border: 0;
      font-size: 14px;
      font-weight: 700;
    }
    tbody td {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      width: auto;
      text-align: right;
      padding: 6px 0;
      border: 0;
      border-top: var(--card-border);
      font-size: 13px;
    }
    tbody td::before {
      content: attr(data-tier);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--meta);
      text-align: left;
    }
    /* Premium-nivåns etikett i guld — matchar priskortet */
    tbody td.cell-premium::before {
      color: var(--gold);
    }
    /* ✓/— behåller sin färg; strängvärden blir mörk text för läsbarhet */
    tbody td.cell--text {
      color: var(--text);
    }
  }

  /* ── FAQ ── */
  .faq {
    margin-top: 48px;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .faq-item {
    background: var(--surface);
    border: var(--card-border);
    border-radius: var(--r-card);
    padding: 0 16px;
  }
  .faq-item summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 15px 0;
    cursor: pointer;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-q {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
  }
  .faq-icon {
    font-size: 18px;
    color: var(--meta);
    transition: transform var(--t-fast) ease-out;
  }
  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
  }
  .faq-a {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text);
    margin: 0;
    padding: 0 0 16px;
  }

  @media (min-width: 1024px) {
    .hin-hero-inner {
      padding: 44px var(--page-pad) 76px;
      display: grid;
      grid-template-columns: 1.15fr 1fr;
      gap: 48px;
      align-items: center;
    }
    .hin-hero-media {
      margin-top: 0;
      border-radius: var(--r-card-lg);
    }
    .hin-hero-media :global(img) {
      height: 320px;
    }
    .hin-title {
      font-size: 66px;
    }
    .hin-intro {
      font-size: 16px;
      max-width: 520px;
    }
    .sheet {
      margin-top: -26px;
    }
    .sheet-inner {
      padding: 48px var(--page-pad) 72px;
    }
    .plans {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      align-items: stretch;
    }
    .plan {
      padding: 30px;
    }
    .plan--pro {
      transform: translateY(-8px);
    }
    .plan-name {
      font-size: 26px;
    }
    .plan-amount {
      font-size: 40px;
    }
    .benefits {
      margin-top: 72px;
    }
    .benefit-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .benefit-card {
      padding: 24px;
    }
    .compare {
      margin-top: 72px;
    }
    .compare-title {
      font-size: 30px;
      margin-bottom: 20px;
    }
    table {
      font-size: 14px;
    }
    .faq {
      margin-top: 64px;
      max-width: 820px;
    }
  }
</style>
