---
/** Hem (wireframe 2b mobil / 3c desktop) — delad mellan fi (/) och sv (/sv/). */
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SearchForm from '../SearchForm.astro';
import ArtistCard from '../ArtistCard.astro';
import { styleImages } from '../../lib/styleImages';
import heroTatuoija from '../../assets/bilder/hero-tatuoija.png';
import { useTranslations, localePath, type Locale } from '../../i18n/ui';
import {
  getCitiesSorted,
  getStylesSorted,
  getStudios,
  sortStudios,
  studioCountByCity,
  cityDisplayName,
  styleDisplayName,
} from '../../lib/content';
import { jsonLdString, webSiteLd } from '../../lib/schema';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const p = (path: string) => localePath(locale, path);

const cities = await getCitiesSorted();
const styles = await getStylesSorted();
const studios = await getStudios();
const counts = await studioCountByCity();

const cityById = new Map(cities.map((city) => [city.id, city]));
const styleById = new Map(styles.map((style) => [style.id, style]));

const featured = sortStudios(studios.filter((studio) => studio.data.premium)).slice(0, 3);
// Störst först — griden visar topp 6, resten nås via "Kaikki →"
const citiesByCount = [...cities].sort(
  (a, b) =>
    (counts.get(b.id) ?? 0) - (counts.get(a.id) ?? 0) ||
    cityDisplayName(a, locale).localeCompare(cityDisplayName(b, locale), locale),
);
const topCities = citiesByCount.slice(0, 6);
const popularCities = citiesByCount.slice(0, 3);

function studioMeta(studio: (typeof studios)[number]): string {
  const city = studio.data.city ? cityById.get(studio.data.city) : undefined;
  const place = city ? cityDisplayName(city, locale) : (studio.data.place ?? '');
  return [studio.data.district, place].filter(Boolean).join(', ');
}
function studioStyleNames(studio: (typeof studios)[number]): string[] {
  return studio.data.styles.map((slug) => {
    const style = styleById.get(slug);
    return style ? styleDisplayName(style, locale) : slug;
  });
}

// Bläck-gradienter i olika valörer (#1c1c22 → #4d3230-spannet, effekt-demon).
// Byts mot egna/licensierade miljöbilder senare (Bildpolicy §4).
const ink = (angle: number, from: string, to: string, mid?: string) =>
  mid
    ? `linear-gradient(${angle}deg, ${from} 0%, ${mid} 55%, ${to} 100%)`
    : `linear-gradient(${angle}deg, ${from} 0%, ${to} 100%)`;

// Fallback-gradienter för stilar utan foto i styleImages
const styleGradients = [
  ink(160, '#1c1c22', '#2f2732'),
  ink(200, '#232029', '#3d2f34'),
  ink(150, '#17171c', '#2b2229'),
  ink(215, '#241f26', '#4d3230'),
  ink(170, '#1e1c26', '#43302f'),
  ink(190, '#211f2b', '#35282b'),
];

// Domän = brand: "Tatuoijat.fi — Suomen tatuoijat ja tatuointiliikkeet"
// ger naturlig exakt träff på "tatuoijat"-sökningar (handoff §7).
const title = `${t('site.name')} — ${t('home.metaSuffix')}`;

// WebSite-entiteten pekar alltid på sajtroten, oavsett locale
const site = Astro.site!;
const webSite = webSiteLd(
  t('site.name'),
  site.href,
  `${new URL('/tatuoijat/', site).href}?tyyli={search_term_string}`,
);
---

<BaseLayout title={title} description={t('home.metaDescription')} locale={locale} path="/" hasAlternate>
  <script type="application/ld+json" set:html={jsonLdString(webSite)} slot="head" />
  <!-- ================= HERO: fullbredds-bild, sticky bakom arket ================= -->
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <Image
        src={heroTatuoija}
        alt=""
        widths={[640, 1024, 1440, 1920]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="hero-shade" aria-hidden="true"></div>
    <div class="container hero-inner">
      <h1 class="hero-title">{t('site.name')}</h1>
      <p class="hero-tagline">{t('site.description')}</p>
    </div>
  </section>

  <!-- ================= BENVIT "ARK" — glider över heron ================= -->
  <div class="sheet grain">
    <div class="container sheet-inner">
      <!-- Flytande sökkort ÖVER skarven — halva på mörkt, halva på ljust -->
      <div class="float-search" id="haku">
        <SearchForm
          locale={locale}
          cities={cities}
          styles={styles}
          idPrefix="hm"
          popularCities={popularCities}
        />
      </div>

      <!-- Nostetut artistit — döljs tills premium-profiler finns -->
      {
        featured.length > 0 && (
          <section class="section" aria-labelledby="featured-title">
            <div class="section-head">
              <div>
                <p class="eyebrow">{t('home.featured.eyebrow')}</p>
                <h2 class="section-title" id="featured-title">{t('home.featured.title')}</h2>
              </div>
              <a class="ink-link section-all" href={p('/tatuoijat/')}>{t('home.all')} →</a>
            </div>
            <div class="featured-grid reveal-stagger">
              {featured.map((studio) => (
                <ArtistCard
                  slug={studio.id}
                  name={studio.data.name}
                  meta={studioMeta(studio)}
                  styleNames={studioStyleNames(studio)}
                  premium={studio.data.premium}
                  size="featured"
                  locale={locale}
                />
              ))}
            </div>
            <!-- Säljruta: nästa Premium-plats -->
            <a class="premium-cta" href={p('/liity/')}>
              <div class="premium-cta-copy">
                <span class="badge-featured">★ {t('card.featured')}</span>
                <h3 class="premium-cta-title">{t('home.premiumCta.title')}</h3>
                <p class="premium-cta-text">{t('home.premiumCta.text')}</p>
              </div>
              <span class="btn-cta premium-cta-btn">{t('home.premiumCta.button')}</span>
            </a>
          </section>
        )
      }

      <!-- Selaa tyylin mukaan — sajtens visuella centrum, extra luft -->
      <section class="section section--styles" aria-labelledby="styles-title">
        <div class="section-head">
          <div>
            <p class="eyebrow">{t('home.styles.eyebrow')}</p>
            <h2 class="section-title" id="styles-title">{t('home.styles.title')}</h2>
          </div>
        </div>
        <div class="style-strip reveal-stagger">
          {
            styles.map((style, index) => (
              <a class="style-card" href={p(`/tyylit/${style.id}/`)}>
                {styleImages[style.id] ? (
                  <Image
                    class="style-photo"
                    src={styleImages[style.id]!}
                    alt=""
                    widths={[400, 800]}
                    sizes="(min-width: 1024px) 33vw, 40vw"
                    loading="lazy"
                  />
                ) : (
                  <span
                    class="style-bg grain-dark"
                    style={`background:${styleGradients[index % styleGradients.length]}`}
                    aria-hidden="true"
                  />
                )}
                <span class="style-name">{styleDisplayName(style, locale)}</span>
                <span class="style-arrow" aria-hidden="true">→</span>
              </a>
            ))
          }
        </div>
      </section>

      <!-- Selaa kaupungin mukaan -->
      <section class="section section--last" aria-labelledby="cities-title">
        <div class="section-head">
          <div>
            <p class="eyebrow">{t('home.cities.eyebrow')}</p>
            <h2 class="section-title" id="cities-title">{t('home.cities.title')}</h2>
          </div>
          <a class="ink-link section-all" href={p('/tatuoijat/')}>{t('home.all')} →</a>
        </div>
        <div class="city-grid reveal-stagger">
          {
            topCities.map((city) => {
              const count = counts.get(city.id) ?? 0;
              return (
                <a class="city-card" href={p(`/tatuoijat/${city.id}/`)}>
                  <span class="city-info">
                    <span class="city-name">
                      {cityDisplayName(city, locale)}
                      <span class="city-arrow" aria-hidden="true">→</span>
                    </span>
                  </span>
                  {count > 0 && (
                    <span class="city-count">
                      <span class="city-num" aria-hidden="true">{count}</span>
                      <span class="city-num-label">
                        {count === 1
                          ? t('home.artistCount.one').replace(/^1\s*/, '')
                          : t('home.artistCount.many', { n: '' }).trim()}
                      </span>
                      <span class="visually-hidden">
                        {count === 1
                          ? t('home.artistCount.one')
                          : t('home.artistCount.many', { n: count })}
                      </span>
                    </span>
                  )}
                </a>
              );
            })
          }
        </div>
      </section>
    </div>
  </div>

  <!-- ================= NÄIN SE TOIMII (bläcksvart) ================= -->
  <section class="how" aria-labelledby="how-title">
    <div class="container how-inner">
      <p class="eyebrow">{t('how.eyebrow')}</p>
      <h2 class="section-title how-title" id="how-title">{t('how.title')}</h2>
      <div class="how-steps">
        {
          (['step1', 'step2', 'step3'] as const).map((step, index) => (
            <div class="how-step">
              <span class="how-number" aria-hidden="true">{`0${index + 1}`}</span>
              <div>
                <h3 class="how-step-title">{t(`how.${step}.title`)}</h3>
                <p class="how-step-text">{t(`how.${step}.text`)}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<!-- IntersectionObserver-fallback för hero-scrubben i webbläsare utan
     CSS scroll-driven animations (CLAUDE.md, Motion). -->
<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!CSS.supports('animation-timeline: scroll()') && !reduceMotion) {
    const hero = document.querySelector('.hero');
    const media = document.querySelector('.hero-media');
    if (hero && media) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          media.classList.toggle('is-scrolled', (entry?.intersectionRatio ?? 1) < 0.55);
        },
        { threshold: [0.55] },
      );
      observer.observe(hero);
    }
  }
</script>

<style>
  /* ================= Hero: fullbredds-bild ================= */
  .hero {
    position: sticky;
    top: 0;
    z-index: 0;
    overflow: hidden;
    background: var(--ink);
  }
  .hero-media {
    position: absolute;
    inset: 0;
  }
  .hero-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 72% 40%; /* artisten till höger i bild */
    display: block;
    filter: saturate(0.9);
  }
  /* Skugglager så typografin alltid har kontrast: mörk vänsterkant +
     mjuk övergång mot arket i botten */
  .hero-shade {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(
        180deg,
        rgba(16, 16, 20, 0.25) 0%,
        rgba(16, 16, 20, 0.1) 40%,
        rgba(16, 16, 20, 0.72) 82%,
        #101014 100%
      ),
      linear-gradient(90deg, rgba(16, 16, 20, 0.7) 0%, rgba(16, 16, 20, 0.15) 55%, rgba(16, 16, 20, 0) 100%);
  }
  .hero-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 470px;
    padding: 0 var(--page-pad) 74px;
  }
  /* Affisch-typo */
  .hero-title {
    font-size: clamp(56px, 15vw, 72px);
    line-height: 0.92;
    letter-spacing: 0.01em;
    color: var(--text-light);
  }
  .hero-tagline {
    margin: 10px 0 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-light);
    opacity: 0.8;
    max-width: 320px;
  }

  @media (min-width: 1024px) {
    .hero-inner {
      min-height: 640px;
      padding-bottom: 104px;
    }
    .hero-title {
      font-size: clamp(96px, 9.5vw, 148px);
      line-height: 0.9;
    }
    .hero-tagline {
      margin: 22px 0 0;
      font-size: 17px;
      line-height: 1.55;
      max-width: 460px;
    }
  }

  /* Hero-scrub: bilden zoomar ut och tonar medan MUSTE-typografin sitter
     kvar. Native CSS scroll-driven animation; IO-fallback i <script> ovan. */
  @media (prefers-reduced-motion: no-preference) {
    .hero-media {
      transform: scale(1.06);
      transform-origin: 50% 30%;
    }
    @supports (animation-timeline: scroll()) {
      .hero-media {
        animation: hero-scrub linear both;
        animation-timeline: scroll();
        animation-range: 0 560px;
      }
    }
    .hero-media.is-scrolled {
      transform: scale(1);
      opacity: 0.4;
      transition:
        transform 700ms var(--ease-out),
        opacity 700ms var(--ease-out);
    }
  }
  @keyframes hero-scrub {
    to {
      transform: scale(1);
      opacity: 0.35;
    }
  }

  /* ================= Arket ================= */
  .sheet {
    position: relative;
    z-index: 1;
    background: var(--paper);
    border-radius: var(--r-sheet) var(--r-sheet) 0 0;
    margin-top: var(--sheet-overlap);
  }
  .sheet-inner {
    padding: 0 16px 32px;
  }
  .float-search {
    position: relative;
    margin-top: -44px;
  }

  .section {
    margin-top: 34px;
    padding: 0 4px;
  }
  .section--styles {
    margin-top: 48px;
    margin-bottom: 48px;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 16px;
  }
  .section-all {
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
  }

  .featured-grid {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* "Haluatko näkyä tässä?" — säljruta för nästa Premium-plats */
  .premium-cta {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 14px;
    background:
      radial-gradient(120% 140% at 85% 0%, rgba(201, 162, 39, 0.12) 0%, rgba(16, 16, 20, 0) 55%),
      var(--ink);
    border-radius: var(--r-card-lg);
    padding: 22px;
    text-decoration: none;
    transition:
      transform var(--t-med) var(--ease-out),
      box-shadow var(--t-med) var(--ease-out);
  }
  .premium-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(16, 16, 20, 0.2);
  }
  .premium-cta-title {
    font-size: 22px;
    color: var(--text-light);
    margin: 12px 0 0;
  }
  .premium-cta-text {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--meta);
    margin: 8px 0 0;
    max-width: 420px;
  }
  .premium-cta-btn {
    width: auto;
    align-self: flex-start;
    padding: 13px 26px;
  }

  /* Stilgalleriet: bläck-gradientplattor, horisontell scroll-snap med peek */
  .style-strip {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding: 0 0 8px;
    margin-right: -16px;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
  }
  .style-strip::-webkit-scrollbar {
    display: none;
  }
  .style-card {
    flex: none;
    position: relative;
    width: 148px;
    height: 178px;
    border-radius: 10px;
    overflow: hidden;
    scroll-snap-align: start;
    text-decoration: none;
    isolation: isolate;
  }
  .style-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    transition: transform var(--t-med) var(--ease-out);
  }
  .style-card :global(.style-photo) {
    position: absolute;
    inset: 0;
    z-index: -1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* enhetlig ton över alla plattor */
    filter: saturate(0.8) contrast(0.98);
    transition: transform var(--t-med) var(--ease-out);
  }
  .style-card:hover :global(.style-photo) {
    transform: scale(1.03);
  }
  .style-card::after {
    /* mörkare fot så namnet alltid har kontrast */
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 60%;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(16, 16, 20, 0) 0%, rgba(16, 16, 20, 0.45) 100%);
  }
  .style-name {
    position: absolute;
    left: 14px;
    bottom: 12px;
    z-index: 1;
    font-family: var(--font-display);
    font-size: 17px;
    color: #fff;
    text-shadow: 0 1px 8px rgba(16, 16, 20, 0.5);
    transition: transform var(--t-med) var(--ease-out);
  }
  .style-arrow {
    position: absolute;
    right: 14px;
    bottom: 12px;
    z-index: 1;
    color: var(--text-light);
    font-size: 15px;
    opacity: 0.55;
    transition:
      transform var(--t-med) var(--ease-out),
      opacity var(--t-med) var(--ease-out);
  }
  .style-card:hover .style-bg {
    transform: scale(1.03);
  }
  .style-card:hover .style-name {
    transform: translateY(-4px);
  }
  .style-card:hover .style-arrow {
    opacity: 1;
    transform: translateX(3px);
  }

  /* Stads-kort: namn med bläck-underline, antal som stor siffra, glidande pil */
  .city-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .city-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    background: var(--surface);
    border: var(--card-border-strong);
    border-radius: var(--r-card);
    padding: 16px;
    text-decoration: none;
    transition:
      transform var(--t-med) var(--ease-out),
      box-shadow var(--t-med) var(--ease-out);
  }
  .city-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(16, 16, 20, 0.12);
  }
  .city-name {
    position: relative;
    display: inline-block;
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--text);
  }
  .city-name::after {
    /* bläck-underline som "blöder" ut från vänster (effekt-demon) */
    content: '';
    position: absolute;
    left: 0;
    right: 16px;
    bottom: -3px;
    height: 2px;
    background: var(--text);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--t-med) var(--ease-out);
  }
  .city-card:hover .city-name::after {
    transform: scaleX(1);
  }
  .city-arrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 13px;
    margin-left: 6px;
    opacity: 0;
    transform: translateX(-6px);
    transition:
      transform var(--t-med) var(--ease-out),
      opacity var(--t-med) var(--ease-out);
  }
  .city-card:hover .city-arrow {
    opacity: 1;
    transform: translateX(0);
  }
  .city-count {
    text-align: right;
    line-height: 1;
  }
  .city-num {
    display: block;
    font-family: var(--font-display);
    font-size: 26px;
    color: var(--border-on-paper);
    transition: color var(--t-med) ease-out;
  }
  .city-card:hover .city-num {
    color: var(--meta);
  }
  .city-num-label {
    display: block;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--meta);
    margin-top: 4px;
  }

  @media (min-width: 1024px) {
    .sheet-inner {
      padding: 0 var(--page-pad) 56px;
    }
    .float-search {
      max-width: 880px;
      margin: -40px auto 0;
    }
    .section {
      margin-top: 56px;
      padding: 0;
    }
    .section--styles {
      margin-top: 88px;
      margin-bottom: 88px;
    }
    .section-head {
      margin-bottom: 22px;
    }
    .section-all {
      font-size: 13px;
    }
    .featured-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .premium-cta {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 32px;
      margin-top: 20px;
      padding: 28px 32px;
    }
    .premium-cta-title {
      font-size: 30px;
    }
    .premium-cta-btn {
      flex: none;
    }
    .style-strip {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      overflow: visible;
      margin-right: 0;
      padding: 0;
    }
    .style-card {
      width: auto;
      height: 210px;
      border-radius: var(--r-card);
    }
    .style-name {
      left: 18px;
      bottom: 15px;
      font-size: 22px;
    }
    .style-arrow {
      right: 18px;
      bottom: 15px;
      font-size: 17px;
    }
    .city-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }
    .city-card {
      padding: 20px;
    }
    .city-name {
      font-size: 17px;
    }
    .city-num {
      font-size: 34px;
    }
  }

  /* Staggered reveal: kort fadar upp sekventiellt när de scrollas in.
     Progressive enhancement — utan stöd visas allt direkt. */
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .reveal-stagger > :global(*) {
        animation: reveal-up 0.6s var(--ease-out) both;
        animation-timeline: view();
        animation-range: entry 0% entry 42%;
      }
      .reveal-stagger > :global(*:nth-child(2)) {
        animation-range: entry 6% entry 48%;
      }
      .reveal-stagger > :global(*:nth-child(3)) {
        animation-range: entry 12% entry 54%;
      }
      .reveal-stagger > :global(*:nth-child(4)) {
        animation-range: entry 18% entry 60%;
      }
      .reveal-stagger > :global(*:nth-child(5)) {
        animation-range: entry 24% entry 66%;
      }
      .reveal-stagger > :global(*:nth-child(n + 6)) {
        animation-range: entry 30% entry 72%;
      }
    }
  }
  @keyframes reveal-up {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
  }

