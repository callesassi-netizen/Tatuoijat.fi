---
/** Hem (wireframe 2b mobil / 3c desktop) — delad mellan fi (/) och sv (/sv/). */
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SearchForm from '../SearchForm.astro';
import ArtistCard from '../ArtistCard.astro';
import { styleImages } from '../../lib/styleImages';
import heroTatuoija from '../../assets/bilder/hero-tatuoija.png';
import tatuoijaMuotokuva from '../../assets/bilder/tatuoija-muotokuva.png';
import tatuoijaStudiossa from '../../assets/bilder/tatuoija-studiossa.png';
import japanilainenHiha from '../../assets/bilder/japanilainen-hiha.png';
import flashTraditional from '../../assets/bilder/flash-traditional.png';
import enkeliRealismi from '../../assets/bilder/enkeli-realismi.png';
import { useTranslations, localePath, type Locale } from '../../i18n/ui';
import {
  getCitiesSorted,
  getStylesSorted,
  getArtists,
  sortArtists,
  artistCountByCity,
  cityDisplayName,
  styleDisplayName,
} from '../../lib/content';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const p = (path: string) => localePath(locale, path);

const cities = await getCitiesSorted();
const styles = await getStylesSorted();
const artists = await getArtists();
const counts = await artistCountByCity();

const cityById = new Map(cities.map((city) => [city.id, city]));
const styleById = new Map(styles.map((style) => [style.id, style]));

const featured = sortArtists(artists.filter((artist) => artist.data.premium)).slice(0, 3);
// Störst först — griden visar topp 6, resten nås via "Kaikki →"
const citiesByCount = [...cities].sort(
  (a, b) =>
    (counts.get(b.id) ?? 0) - (counts.get(a.id) ?? 0) ||
    cityDisplayName(a, locale).localeCompare(cityDisplayName(b, locale), locale),
);
const topCities = citiesByCount.slice(0, 6);
const popularCities = citiesByCount.slice(0, 3);

function artistMeta(artist: (typeof artists)[number]): string {
  const city = artist.data.city ? cityById.get(artist.data.city) : undefined;
  const place = city ? cityDisplayName(city, locale) : (artist.data.place ?? '');
  const studio =
    artist.data.studio && artist.data.studio !== artist.data.name ? artist.data.studio : '';
  return [place, studio].filter(Boolean).join(' · ');
}
function artistStyleNames(artist: (typeof artists)[number]): string[] {
  return artist.data.styles.map((slug) => {
    const style = styleById.get(slug);
    return style ? styleDisplayName(style, locale) : slug;
  });
}

// Bläck-gradienter i olika valörer (#1c1c22 → #4d3230-spannet, effekt-demon).
// Byts mot egna/licensierade miljöbilder senare (Bildpolicy §4).
const ink = (angle: number, from: string, to: string, mid?: string) =>
  mid
    ? `linear-gradient(${angle}deg, ${from} 0%, ${mid} 55%, ${to} 100%)`
    : `linear-gradient(${angle}deg, ${from} 0%, ${to} 100%)`;

// Masonry-collage av egna miljöfoton (Bildpolicy §4).
// { height } + antingen { image } eller { gradient } (fallback).
type Tile = { height: number; image?: ImageMetadata; gradient?: string };
const collageMobile: Tile[][] = [
  [
    { height: 150, image: heroTatuoija },
    { height: 104, image: flashTraditional },
    { height: 88, image: enkeliRealismi },
  ],
  [
    { height: 96, image: japanilainenHiha },
    { height: 158, image: tatuoijaMuotokuva },
    { height: 88, image: tatuoijaStudiossa },
  ],
];
const collageDesktop: Tile[][] = [
  [
    { height: 150, image: japanilainenHiha },
    { height: 196, image: heroTatuoija },
  ],
  [
    { height: 110, image: enkeliRealismi },
    { height: 240, image: tatuoijaMuotokuva },
  ],
  [
    { height: 170, image: tatuoijaStudiossa },
    { height: 210, image: flashTraditional },
  ],
];

// Fallback-gradienter för stilar utan foto i styleImages
const styleGradients = [
  ink(160, '#1c1c22', '#2f2732'),
  ink(200, '#232029', '#3d2f34'),
  ink(150, '#17171c', '#2b2229'),
  ink(215, '#241f26', '#4d3230'),
  ink(170, '#1e1c26', '#43302f'),
  ink(190, '#211f2b', '#35282b'),
];

const title = `${t('site.name')} — ${t('site.tagline')} | ${t('home.metaSuffix')}`;
---

<BaseLayout title={title} description={t('site.description')} locale={locale} path="/" hasAlternate>
  <!-- ================= HERO (bläcksvart, sticky bakom arket) ================= -->
  <section class="hero">
    <div class="container hero-inner">
      <!-- Mobil: masonry-collage med typografi ovanpå (wireframe 1b) -->
      <div class="hero-mobile">
        <div class="hero-collage collage-mobile" aria-hidden="true">
          {
            collageMobile.map((column) => (
              <div class="collage-col">
                {column.map((tile) =>
                  tile.image ? (
                    <div class="tile tile--photo" style={`height:${tile.height}px`}>
                      <Image
                        src={tile.image}
                        alt=""
                        widths={[400, 800]}
                        sizes="50vw"
                        loading="eager"
                      />
                    </div>
                  ) : (
                    <div
                      class="tile grain-dark"
                      style={`height:${tile.height}px;background:${tile.gradient}`}
                    />
                  ),
                )}
              </div>
            ))
          }
        </div>
        <div class="hero-vignette" aria-hidden="true"></div>
        <div class="hero-overlay">
          <h1 class="hero-title">{t('site.name')}</h1>
          <p class="hero-tagline">{t('hero.tagline')}</p>
        </div>
      </div>

      <!-- Desktop: affisch-typo vänster, masonry-collage höger (wireframe 3c) -->
      <div class="hero-desktop">
        <div class="hero-copy">
          <h1 class="hero-title" aria-hidden="true">{t('site.name')}</h1>
          <p class="hero-tagline">{t('site.description')}</p>
        </div>
        <div class="collage-wrap">
          <div class="hero-collage collage-desktop" aria-hidden="true">
            {
              collageDesktop.map((column) => (
                <div class="collage-col">
                  {column.map((tile) =>
                    tile.image ? (
                      <div class="tile tile--photo" style={`height:${tile.height}px`}>
                        <Image
                          src={tile.image}
                          alt=""
                          widths={[400, 800]}
                          sizes="20vw"
                          loading="eager"
                        />
                      </div>
                    ) : (
                      <div
                        class="tile grain-dark"
                        style={`height:${tile.height}px;background:${tile.gradient}`}
                      />
                    ),
                  )}
                </div>
              ))
            }
          </div>
          <div class="hero-vignette hero-vignette--desktop" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= BENVIT "ARK" — glider över heron ================= -->
  <div class="sheet grain">
    <div class="container sheet-inner">
      <!-- Flytande sökkort ÖVER skarven — halva på mörkt, halva på ljust -->
      <div class="float-search" id="haku">
        <SearchForm
          locale={locale}
          cities={cities}
          styles={styles}
          idPrefix="hm"
          popularCities={popularCities}
        />
      </div>

      <!-- Nostetut artistit — döljs tills premium-profiler finns -->
      {
        featured.length > 0 && (
          <section class="section" aria-labelledby="featured-title">
            <div class="section-head">
              <div>
                <p class="eyebrow">{t('home.featured.eyebrow')}</p>
                <h2 class="section-title" id="featured-title">{t('home.featured.title')}</h2>
              </div>
              <a class="ink-link section-all" href={p('/tatuoijat/')}>{t('home.all')} →</a>
            </div>
            <div class="featured-grid reveal-stagger">
              {featured.map((artist) => (
                <ArtistCard
                  slug={artist.id}
                  name={artist.data.name}
                  meta={artistMeta(artist)}
                  styleNames={artistStyleNames(artist)}
                  premium={artist.data.premium}
                  size="featured"
                  locale={locale}
                />
              ))}
            </div>
            <!-- Säljruta: nästa Premium-plats -->
            <a class="premium-cta" href={p('/liity/')}>
              <div class="premium-cta-copy">
                <span class="badge-featured">★ {t('card.featured')}</span>
                <h3 class="premium-cta-title">{t('home.premiumCta.title')}</h3>
                <p class="premium-cta-text">{t('home.premiumCta.text')}</p>
              </div>
              <span class="btn-cta premium-cta-btn">{t('home.premiumCta.button')}</span>
            </a>
          </section>
        )
      }

      <!-- Selaa tyylin mukaan — sajtens visuella centrum, extra luft -->
      <section class="section section--styles" aria-labelledby="styles-title">
        <div class="section-head">
          <div>
            <p class="eyebrow">{t('home.styles.eyebrow')}</p>
            <h2 class="section-title" id="styles-title">{t('home.styles.title')}</h2>
          </div>
        </div>
        <div class="style-strip reveal-stagger">
          {
            styles.map((style, index) => (
              <a class="style-card" href={p(`/tyylit/${style.id}/`)}>
                {styleImages[style.id] ? (
                  <Image
                    class="style-photo"
                    src={styleImages[style.id]!}
                    alt=""
                    widths={[400, 800]}
                    sizes="(min-width: 1024px) 33vw, 40vw"
                    loading="lazy"
                  />
                ) : (
                  <span
                    class="style-bg grain-dark"
                    style={`background:${styleGradients[index % styleGradients.length]}`}
                    aria-hidden="true"
                  />
                )}
                <span class="style-name">{styleDisplayName(style, locale)}</span>
                <span class="style-arrow" aria-hidden="true">→</span>
              </a>
            ))
          }
        </div>
      </section>

      <!-- Selaa kaupungin mukaan -->
      <section class="section section--last" aria-labelledby="cities-title">
        <div class="section-head">
          <div>
            <p class="eyebrow">{t('home.cities.eyebrow')}</p>
            <h2 class="section-title" id="cities-title">{t('home.cities.title')}</h2>
          </div>
          <a class="ink-link section-all" href={p('/tatuoijat/')}>{t('home.all')} →</a>
        </div>
        <div class="city-grid reveal-stagger">
          {
            topCities.map((city) => {
              const count = counts.get(city.id) ?? 0;
              return (
                <a class="city-card" href={p(`/tatuoijat/${city.id}/`)}>
                  <span class="city-info">
                    <span class="city-name">
                      {cityDisplayName(city, locale)}
                      <span class="city-arrow" aria-hidden="true">→</span>
                    </span>
                  </span>
                  {count > 0 && (
                    <span class="city-count">
                      <span class="city-num" aria-hidden="true">{count}</span>
                      <span class="city-num-label">
                        {count === 1
                          ? t('home.artistCount.one').replace(/^1\s*/, '')
                          : t('home.artistCount.many', { n: '' }).trim()}
                      </span>
                      <span class="visually-hidden">
                        {count === 1
                          ? t('home.artistCount.one')
                          : t('home.artistCount.many', { n: count })}
                      </span>
                    </span>
                  )}
                </a>
              );
            })
          }
        </div>
      </section>
    </div>
  </div>

  <!-- ================= NÄIN SE TOIMII (bläcksvart) ================= -->
  <section class="how" aria-labelledby="how-title">
    <div class="container how-inner">
      <p class="eyebrow">{t('how.eyebrow')}</p>
      <h2 class="section-title how-title" id="how-title">{t('how.title')}</h2>
      <div class="how-steps">
        {
          (['step1', 'step2', 'step3'] as const).map((step, index) => (
            <div class="how-step">
              <span class="how-number" aria-hidden="true">{`0${index + 1}`}</span>
              <div>
                <h3 class="how-step-title">{t(`how.${step}.title`)}</h3>
                <p class="how-step-text">{t(`how.${step}.text`)}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<!-- IntersectionObserver-fallback för hero-scrubben i webbläsare utan
     CSS scroll-driven animations (CLAUDE.md, Motion). -->
<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!CSS.supports('animation-timeline: scroll()') && !reduceMotion) {
    const hero = document.querySelector('.hero');
    const collages = document.querySelectorAll('.hero-collage');
    if (hero && collages.length) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          collages.forEach((collage) =>
            collage.classList.toggle('is-scrolled', (entry?.intersectionRatio ?? 1) < 0.55),
          );
        },
        { threshold: [0.55] },
      );
      observer.observe(hero);
    }
  }
</script>

<style>
  /* ================= Hero ================= */
  .hero {
    position: sticky;
    top: 0;
    z-index: 0;
    background:
      radial-gradient(120% 90% at 18% 22%, rgba(77, 50, 48, 0.16) 0%, rgba(16, 16, 20, 0) 60%),
      var(--ink);
  }
  .hero-mobile {
    position: relative;
  }
  .collage-mobile {
    display: flex;
    gap: 6px;
    padding: 6px 6px 0;
  }
  .collage-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    justify-content: flex-end;
  }
  .tile {
    border-radius: 6px;
  }
  .tile--photo {
    overflow: hidden;
    background: var(--ink);
  }
  .tile--photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* tonas in i bläck-paletten */
    filter: saturate(0.85);
  }

  /* Mjuk vinjett över collaget så typografin får kontrast */
  .hero-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      130% 110% at 50% 45%,
      rgba(16, 16, 20, 0) 38%,
      rgba(16, 16, 20, 0.38) 78%,
      rgba(16, 16, 20, 0.6) 100%
    );
  }
  .hero-overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 80px var(--page-pad) 70px;
    background: linear-gradient(
      180deg,
      rgba(16, 16, 20, 0) 0%,
      rgba(16, 16, 20, 0.55) 34%,
      rgba(16, 16, 20, 0.94) 64%,
      #101014 100%
    );
  }
  /* Affisch-typo */
  .hero-title {
    font-size: clamp(56px, 15vw, 72px);
    line-height: 0.92;
    letter-spacing: 0.01em;
    color: var(--text-light);
  }
  .hero-tagline {
    margin: 10px 0 0;
    font-size: 14px;
    line-height: 1.45;
    color: var(--text-light);
    opacity: 0.75;
    max-width: 300px;
  }
  .hero-desktop {
    display: none;
  }

  @media (min-width: 1024px) {
    .hero-mobile {
      display: none;
    }
    .hero-desktop {
      display: grid;
      grid-template-columns: 1.15fr 1fr;
      gap: 48px;
      align-items: end;
      padding: 56px var(--page-pad) 0;
    }
    .hero-copy {
      padding-bottom: 88px;
    }
    .hero-desktop .hero-title {
      font-size: clamp(96px, 9.5vw, 148px);
      line-height: 0.9;
    }
    .hero-desktop .hero-tagline {
      margin: 22px 0 0;
      font-size: 17px;
      line-height: 1.55;
      color: var(--meta);
      opacity: 1;
      max-width: 460px;
    }
    .collage-wrap {
      position: relative;
    }
    .collage-desktop {
      display: flex;
      gap: 10px;
      align-items: flex-end;
    }
    .collage-desktop .collage-col {
      gap: 10px;
    }
    .collage-desktop .tile {
      border-radius: 8px;
    }
    .collage-desktop .collage-col .tile:last-child {
      border-radius: 8px 8px 0 0;
    }
    .hero-vignette--desktop {
      background: radial-gradient(
        120% 100% at 50% 40%,
        rgba(16, 16, 20, 0) 45%,
        rgba(16, 16, 20, 0.32) 82%,
        rgba(16, 16, 20, 0.55) 100%
      );
    }
  }

  /* Hero-scrub: collaget skalar/tonar medan MUSTE-typografin sitter kvar.
     Native CSS scroll-driven animation; IO-fallback i <script> ovan. */
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: scroll()) {
      .hero-collage {
        animation: hero-scrub linear both;
        animation-timeline: scroll();
        animation-range: 0 520px;
        transform-origin: 50% 20%;
      }
    }
    .hero-collage.is-scrolled {
      transform: scale(0.94);
      opacity: 0.35;
      transition:
        transform 600ms var(--ease-out),
        opacity 600ms var(--ease-out);
    }
  }
  @keyframes hero-scrub {
    to {
      transform: scale(0.94);
      opacity: 0.3;
    }
  }

  /* ================= Arket ================= */
  .sheet {
    position: relative;
    z-index: 1;
    background: var(--paper);
    border-radius: var(--r-sheet) var(--r-sheet) 0 0;
    margin-top: var(--sheet-overlap);
  }
  .sheet-inner {
    padding: 0 16px 32px;
  }
  .float-search {
    position: relative;
    margin-top: -44px;
  }

  .section {
    margin-top: 34px;
    padding: 0 4px;
  }
  .section--styles {
    margin-top: 48px;
    margin-bottom: 48px;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 16px;
  }
  .section-all {
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
  }

  .featured-grid {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* "Haluatko näkyä tässä?" — säljruta för nästa Premium-plats */
  .premium-cta {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 14px;
    background:
      radial-gradient(120% 140% at 85% 0%, rgba(201, 162, 39, 0.12) 0%, rgba(16, 16, 20, 0) 55%),
      var(--ink);
    border-radius: var(--r-card-lg);
    padding: 22px;
    text-decoration: none;
    transition:
      transform var(--t-med) var(--ease-out),
      box-shadow var(--t-med) var(--ease-out);
  }
  .premium-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(16, 16, 20, 0.2);
  }
  .premium-cta-title {
    font-size: 22px;
    color: var(--text-light);
    margin: 12px 0 0;
  }
  .premium-cta-text {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--meta);
    margin: 8px 0 0;
    max-width: 420px;
  }
  .premium-cta-btn {
    width: auto;
    align-self: flex-start;
    padding: 13px 26px;
  }

  /* Stilgalleriet: bläck-gradientplattor, horisontell scroll-snap med peek */
  .style-strip {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding: 0 0 8px;
    margin-right: -16px;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
  }
  .style-strip::-webkit-scrollbar {
    display: none;
  }
  .style-card {
    flex: none;
    position: relative;
    width: 148px;
    height: 178px;
    border-radius: 10px;
    overflow: hidden;
    scroll-snap-align: start;
    text-decoration: none;
    isolation: isolate;
  }
  .style-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    transition: transform var(--t-med) var(--ease-out);
  }
  .style-card :global(.style-photo) {
    position: absolute;
    inset: 0;
    z-index: -1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* enhetlig ton över alla plattor */
    filter: saturate(0.8) contrast(0.98);
    transition: transform var(--t-med) var(--ease-out);
  }
  .style-card:hover :global(.style-photo) {
    transform: scale(1.03);
  }
  .style-card::after {
    /* mörkare fot så namnet alltid har kontrast */
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 60%;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(16, 16, 20, 0) 0%, rgba(16, 16, 20, 0.45) 100%);
  }
  .style-name {
    position: absolute;
    left: 14px;
    bottom: 12px;
    z-index: 1;
    font-family: var(--font-display);
    font-size: 17px;
    color: #fff;
    text-shadow: 0 1px 8px rgba(16, 16, 20, 0.5);
    transition: transform var(--t-med) var(--ease-out);
  }
  .style-arrow {
    position: absolute;
    right: 14px;
    bottom: 12px;
    z-index: 1;
    color: var(--text-light);
    font-size: 15px;
    opacity: 0.55;
    transition:
      transform var(--t-med) var(--ease-out),
      opacity var(--t-med) var(--ease-out);
  }
  .style-card:hover .style-bg {
    transform: scale(1.03);
  }
  .style-card:hover .style-name {
    transform: translateY(-4px);
  }
  .style-card:hover .style-arrow {
    opacity: 1;
    transform: translateX(3px);
  }

  /* Stads-kort: namn med bläck-underline, antal som stor siffra, glidande pil */
  .city-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .city-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    background: var(--surface);
    border: var(--card-border-strong);
    border-radius: var(--r-card);
    padding: 16px;
    text-decoration: none;
    transition:
      transform var(--t-med) var(--ease-out),
      box-shadow var(--t-med) var(--ease-out);
  }
  .city-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(16, 16, 20, 0.12);
  }
  .city-name {
    position: relative;
    display: inline-block;
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--text);
  }
  .city-name::after {
    /* bläck-underline som "blöder" ut från vänster (effekt-demon) */
    content: '';
    position: absolute;
    left: 0;
    right: 16px;
    bottom: -3px;
    height: 2px;
    background: var(--text);
    transform: scaleX(0);
    transform-origin: left center;
