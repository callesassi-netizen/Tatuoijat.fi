---
/**
 * Stadssida (wireframe 2a mobil / 3d desktop): kompakt mörk hero med
 * filmremsa, flytande sökkort med staden förvald, stil-filterchips
 * (filtrering utan sidladdning), featured först, sedan grid.
 */
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SearchForm from '../SearchForm.astro';
import ArtistCard from '../ArtistCard.astro';
import { useTranslations, localePath, type Locale } from '../../i18n/ui';
import {
  getCitiesSorted,
  getStylesSorted,
  getStudios,
  sortStudios,
  isFeatured,
  isWalkIn,
  localizedBody,
  cityDisplayName,
  styleDisplayName,
} from '../../lib/content';
import { jsonLdString, breadcrumbLd, collectionPageLd, faqLd, CONTENT_UPDATED } from '../../lib/schema';
import { CITY_INDEX_MIN_STUDIOS } from '../../lib/indexing.mjs';
import { citiesIndexPath, cityPath } from '../../lib/routes';

interface Props {
  city: CollectionEntry<'cities'>;
  locale: Locale;
}

const { city, locale } = Astro.props;
const t = useTranslations(locale);
const p = (path: string) => localePath(locale, path);
const site = Astro.site!;

const cities = await getCitiesSorted();
const styles = await getStylesSorted();
const allStudios = await getStudios();
const styleById = new Map(styles.map((style) => [style.id, style]));

const cityName = cityDisplayName(city, locale);
const h1City = locale === 'fi' ? city.data.nameLocative : cityName;
const studios = sortStudios(allStudios.filter((studio) => studio.data.city === city.id));
// Endast Premium pinnas överst med badge; Pro sorteras redan ovanför
// Perus via sortStudios men visas i samma grid som gratislistningarna.
const featured = studios.filter(isFeatured);
const regular = studios.filter((studio) => !isFeatured(studio));
// Walk-in-sektion (handoff §3.4): stadens walk-in-studios, redan tier-sorterade.
// Renderas som kompakt länklista (INTE ArtistCard) — korten sätter unika
// view-transition-name per slug och skulle krocka med huvudgriden. Bara ≥1.
const walkInStudios = studios.filter(isWalkIn);
const intro = localizedBody(city.body, locale);
const countSentence =
  studios.length === 1
    ? t('city.introCount.one')
    : t('city.introCount.many', { n: studios.length });

// GEO.md §1 (svara-först) — de vanligaste tyylejä bland stadens studios,
// riktig data (ingen påhittad "topplista"). Toppmax 4 för läsbar mening.
const styleFreq = new Map<string, number>();
for (const studio of studios) {
  for (const slug of studio.data.styles) styleFreq.set(slug, (styleFreq.get(slug) ?? 0) + 1);
}
const topStyles = [...styleFreq.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 4)
  .map(([slug]) => styleById.get(slug))
  .filter((s): s is NonNullable<typeof s> => Boolean(s));
const topStyleNames = topStyles.map((s) => styleDisplayName(s, locale));
const answerSentence =
  countSentence +
  (topStyleNames.length > 0
    ? ` ${t('city.answer.styles', { styles: topStyleNames.join(', ') })}`
    : '');

// GEO.md §2/§3 — riktig, ärligt besvarbar mini-FAQ (ingen "paras"-krona åt
// någon enskild studio) + FAQPage-schema. Walk-in-frågan visas bara när
// staden faktiskt har ≥1 walk-in-studio. `href` = intern länk till /hinnat
// (§9 topical cluster) — bara på priset-frågan, ren text i schemat.
const faqItems: { q: string; a: string; href?: string }[] = [
  { q: t('city.qa.find.q', { city: h1City }), a: t('city.qa.find.a', { n: studios.length }) },
  { q: t('city.qa.count.q', { city: h1City }), a: countSentence },
  ...(topStyleNames.length > 0
    ? [
        {
          q: t('city.qa.styles.q', { city: h1City }),
          a: t('city.answer.styles', { styles: topStyleNames.join(', ') }),
        },
      ]
    : []),
  ...(walkInStudios.length > 0
    ? [{ q: t('city.qa.walkin.q', { city: h1City }), a: t('city.qa.walkin.a', { n: walkInStudios.length, city: h1City }) }]
    : []),
  { q: t('city.qa.price.q', { city: h1City }), a: t('city.qa.price.a'), href: p('/hinnat/') },
];
const faq = faqLd(faqItems.map(({ q, a }) => ({ q, a })));

function studioMeta(studio: (typeof studios)[number]): string {
  return studio.data.district ?? cityName;
}
function studioStyleNames(studio: (typeof studios)[number]): string[] {
  return studio.data.styles.map((slug) => {
    const style = styleById.get(slug);
    return style ? styleDisplayName(style, locale) : slug;
  });
}

// Filmremsa: bläck-gradientplattor som klipps av arket
const ink = (angle: number, from: string, to: string) =>
  `linear-gradient(${angle}deg, ${from} 0%, ${to} 100%)`;
const filmstrip: [string, number, number][] = [
  [ink(160, '#1c1c22', '#33262a'), 92, 64],
  [ink(200, '#232029', '#3d2f34'), 118, 50],
  [ink(150, '#17171c', '#2b2229'), 76, 72],
  [ink(215, '#241f26', '#4d3230'), 108, 56],
  [ink(170, '#1e1c26', '#43302f'), 96, 66],
  [ink(190, '#211f2b', '#35282b'), 124, 48],
];

// Thin-content-regeln (handoff §3.1): under tröskeln → noindex,follow.
// Sitemap-filtret i astro.config.mjs utesluter samma sidor.
const noindex = studios.length < CITY_INDEX_MIN_STUDIOS;

const path = cityPath(city, locale);
const altPath = cityPath(city, locale === 'fi' ? 'sv' : 'fi');
const title = t('city.metaTitle', { city: cityName, n: studios.length, site: t('site.name') });
const description = t('city.metaDescription', { city: cityName, n: studios.length });

const breadcrumb = breadcrumbLd([
  { name: t('breadcrumb.home'), url: new URL(p('/'), site).href },
  { name: t('nav.cities'), url: new URL(p(citiesIndexPath(locale)), site).href },
  { name: cityName, url: new URL(p(path), site).href },
]);
const collectionPage = collectionPageLd(
  t('city.h1', { city: h1City }),
  new URL(p(path), site).href,
  studios.map((studio) => new URL(p(`/artistit/${studio.id}/`), site).href),
);
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  path={path}
  altPath={altPath}
  hasAlternate
  noindex={noindex}
>
  <script type="application/ld+json" set:html={jsonLdString(breadcrumb)} slot="head" />
  <script type="application/ld+json" set:html={jsonLdString(collectionPage)} slot="head" />
  <script type="application/ld+json" set:html={jsonLdString(faq)} slot="head" />

  <!-- Kompakt mörk hero -->
  <section class="city-hero">
    <div class="container city-hero-inner">
      <a class="back-link ink-link" href={p('/')}>← {t('city.back')}</a>
      <p class="eyebrow">{t('city.eyebrow')}</p>
      <h1 class="city-title">{t('city.h1', { city: h1City })}</h1>
      <p class="city-intro">{answerSentence} {intro}</p>
      <div class="filmstrip" aria-hidden="true">
        {
          filmstrip.map(([gradient, width, height]) => (
            <div
              class="film-tile grain-dark"
              style={`width:${width}px;height:${height}px;background:${gradient}`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Ark + flytande sökkort med staden förvald -->
  <div class="sheet grain">
    <div class="container sheet-inner">
      <div class="float-search">
        <SearchForm
          locale={locale}
          cities={cities}
          styles={styles}
          selectedCity={city.id}
          idPrefix="cs"
          popularCities={cities.slice(0, 4)}
          chipsLabel={t('city.switch')}
          activeCityChip={city.id}
        />
      </div>

      <!-- GEO.md §2: riktig sökfråga som H2 (ingen "paras"-krona åt någon
           enskild studio — svaret är att jämföra listan nedan). -->
      <h2 class="visually-hidden">{t('city.qa.find.q', { city: h1City })}</h2>

      <!-- Stil-filterchips: filtrering utan sidladdning -->
      <div class="filter-bar" data-filter-bar role="group" aria-label={t('city.filterLabel')}>
        <button class="chip chip--active" type="button" data-style="">{t('city.filterAll')}</button>
        {
          styles.map((style) => (
            <button class="chip" type="button" data-style={style.id}>
              {styleDisplayName(style, locale)}
            </button>
          ))
        }
      </div>

      <p
        class="results"
        data-result-count
        data-one={t('city.results.one')}
        data-many={t('city.results.many', { n: '{n}' })}
      >
        {studios.length === 1 ? t('city.results.one') : t('city.results.many', { n: studios.length })}
      </p>

      <!-- Featured först -->
      {
        featured.length > 0 && (
          <div class="featured-list">
            {featured.map((studio) => (
              <div
                class="card-cell"
                data-artist-card
                data-styles={studio.data.styles.join(' ')}
              >
                <ArtistCard
                  slug={studio.id}
                  name={studio.data.name}
                  meta={studioMeta(studio)}
                  styleNames={studioStyleNames(studio)}
                  premium
                  walkIn={isWalkIn(studio)}
                  size="featured"
                  locale={locale}
                />
              </div>
            ))}
          </div>
        )
      }

      <!-- Vanliga listningar: samma kort-anatomi, utan badge -->
      {
        regular.length > 0 && (
          <div class="regular-grid">
            {regular.map((studio) => (
              <div
                class="card-cell"
                data-artist-card
                data-styles={studio.data.styles.join(' ')}
              >
                <ArtistCard
                  slug={studio.id}
                  name={studio.data.name}
                  meta={studioMeta(studio)}
                  styleNames={studioStyleNames(studio)}
                  walkIn={isWalkIn(studio)}
                  size="compact"
                  locale={locale}
                />
              </div>
            ))}
          </div>
        )
      }

      <!-- Tomt läge (byggs enligt handoff-README: States) -->
      <div class="empty" data-empty hidden>
        <p class="empty-title">{t('city.empty.title')}</p>
        <p class="empty-text">{t('city.empty.text')}</p>
        <button class="btn-outline empty-reset" type="button" data-empty-reset>
          {t('city.empty.reset')}
        </button>
      </div>

      <!-- Walk-in-sektion (handoff §3.4): bara om staden har ≥1 walk-in-studio.
           Kompakt länklista → ingen VT-name-krock med huvudgriden ovan. -->
      {
        walkInStudios.length > 0 && (
          <section class="walkin-section" aria-labelledby="walkin-title">
            <h2 class="walkin-title" id="walkin-title">
              {t('city.walkin.title', { city: h1City })}
            </h2>
            <ul class="walkin-list">
              {walkInStudios.map((studio) => (
                <li>
                  <a class="walkin-link" href={p(`/artistit/${studio.id}/`)}>
                    <span class="walkin-name ink-link">{studio.data.name}</span>
                    <span class="walkin-meta">{studioMeta(studio)}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      <!-- GEO.md §9 (topical cluster): korslänk till stilsidorna som faktiskt
           finns i denna stad — riktiga hrefs, inte bara JS-filtret ovan. -->
      {
        topStyles.length > 0 && (
          <section class="crosslink-section" aria-labelledby="crosslink-title">
            <h2 class="crosslink-title" id="crosslink-title">{t('city.stylesLinks.title')}</h2>
            <p class="crosslink-list">
              {topStyles.map((style) => (
                <a class="chip" href={p(`/tyylit/${style.id}/`)}>
                  {t('style.inCity', { style: styleDisplayName(style, locale), city: cityName })}
                </a>
              ))}
            </p>
          </section>
        )
      }

      <!-- Mini-FAQ (GEO.md §1–3): riktiga, ärligt besvarbara frågor + FAQPage-schema ovan -->
      <section class="faq-section" aria-labelledby="faq-title">
        <h2 class="faq-title" id="faq-title">{t('city.faqTitle')}</h2>
        <div class="faq-list">
          {faqItems.map((item) => (
            <details class="faq-item">
              <summary>
                <span class="faq-q">{item.q}</span>
                <span class="faq-icon" aria-hidden="true">+</span>
              </summary>
              <p class="faq-a">
                {item.a}
                {item.href && (
                  <>
                    {' '}
                    <a class="ink-link" href={item.href}>{t('common.priceGuideLink')}</a>
                  </>
                )}
              </p>
            </details>
          ))}
        </div>
      </section>

      <p class="freshness">{t('common.updated', { date: CONTENT_UPDATED })}</p>
    </div>
  </div>
</BaseLayout>

<!-- Filter-ö: göm/visa kort, uppdatera räknare och ?tyyli= i URL:en.
     Utan JS visas hela listan — inget går sönder. -->
<script>
  const bar = document.querySelector<HTMLElement>('[data-filter-bar]');
  if (bar) {
    const chips = Array.from(bar.querySelectorAll<HTMLButtonElement>('button[data-style]'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-artist-card]'));
    const counter = document.querySelector<HTMLElement>('[data-result-count]');
    const empty = document.querySelector<HTMLElement>('[data-empty]');

    function apply(styleSlug: string) {
      let visible = 0;
      for (const card of cards) {
        const cardStyles = (card.dataset.styles ?? '').split(' ');
        const show = styleSlug === '' || cardStyles.includes(styleSlug);
        card.hidden = !show;
        if (show) visible++;
      }
      for (const chip of chips) {
        chip.classList.toggle('chip--active', (chip.dataset.style ?? '') === styleSlug);
      }
      if (counter) {
        counter.textContent =
          visible === 1
            ? (counter.dataset.one ?? '')
            : (counter.dataset.many ?? '').replace('{n}', String(visible));
      }
      if (empty) empty.hidden = visible > 0;
      const url = new URL(window.location.href);
      if (styleSlug) url.searchParams.set('tyyli', styleSlug);
      else url.searchParams.delete('tyyli');
      history.replaceState(null, '', url);
    }

    chips.forEach((chip) => chip.addEventListener('click', () => apply(chip.dataset.style ?? '')));
    document
      .querySelector('[data-empty-reset]')
      ?.addEventListener('click', () => apply(''));

    const initial = new URL(window.location.href).searchParams.get('tyyli') ?? '';
    if (initial && chips.some((chip) => chip.dataset.style === initial)) apply(initial);
  }
</script>

<style>
  .city-hero {
    position: relative;
    z-index: 0;
    background: var(--ink);
  }
  .city-hero-inner {
    padding: 20px var(--page-pad) 0;
  }
  .back-link {
    font-size: 11px;
    font-weight: 600;
    color: var(--meta);
  }
  .city-hero .eyebrow {
    margin-top: 18px;
  }
  .city-title {
    font-size: 34px;
    line-height: 1.06;
    color: var(--text-light);
  }
  .city-intro {
    margin: 10px 0 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--meta);
    max-width: 340px;
  }
  .filmstrip {
    display: flex;
    gap: 6px;
    align-items: flex-end;
    margin-top: 18px;
    overflow: hidden;
  }
  .film-tile {
    flex: none;
    border-radius: 6px 6px 0 0;
  }

  .sheet {
    position: relative;
    z-index: 1;
    background: var(--paper);
    border-radius: var(--r-sheet) var(--r-sheet) 0 0;
    margin-top: -20px;
  }
  .sheet-inner {
    padding: 0 var(--page-pad) 36px;
  }
  .float-search {
    position: relative;
    margin-top: -40px;
  }

  .filter-bar {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    margin: 20px calc(-1 * var(--page-pad)) 0;
    padding: 0 var(--page-pad) 4px;
  }
  .filter-bar::-webkit-scrollbar {
    display: none;
  }
  .filter-bar .chip {
    flex: none;
    font-size: 12px;
    padding: 7px 14px;
    background: none;
    cursor: pointer;
  }
  .filter-bar .chip--active {
    background: var(--flash);
    border-color: var(--flash);
    color: #fff;
  }

  .results {
    font-size: 12.5px;
    color: var(--meta);
    margin: 16px 0 12px;
  }

  .featured-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .featured-list .card-cell[hidden],
  .regular-grid .card-cell[hidden] {
    display: none;
  }
  .regular-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 14px;
  }

  .empty {
    text-align: center;
    padding: 44px 20px;
  }
  .empty-title {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--text);
    margin: 0;
  }
  .empty-text {
    font-size: 13.5px;
    color: var(--meta);
    max-width: 320px;
    margin: 8px auto 18px;
  }
  .empty-reset {
    width: auto;
    display: inline-block;
    padding: 12px 22px;
  }

  /* Walk-in-sektion: kompakt SEO-länklista, samma bläck-underline som övrigt */
  .walkin-section {
    margin-top: 36px;
    padding-top: 28px;
    border-top: var(--card-border);
  }
  .walkin-title {
    font-size: 18px;
    color: var(--text);
    margin-bottom: 12px;
  }
  .walkin-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .walkin-list li + li {
    border-top: 1px solid rgba(16, 16, 20, 0.07);
  }
  .walkin-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 0;
    text-decoration: none;
  }
  .walkin-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
  }
  .walkin-meta {
    font-size: 12px;
    color: var(--meta);
  }

  /* Korslänk till stilsidorna (GEO.md §9) */
  .crosslink-section {
    margin-top: 36px;
    padding-top: 28px;
    border-top: var(--card-border);
  }
  .crosslink-title {
    font-size: 18px;
    color: var(--text);
    margin-bottom: 12px;
  }
  .crosslink-list {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin: 0;
  }

  /* Mini-FAQ (samma mönster som /hinnat och /hinnasto) */
  .faq-section {
    margin-top: 36px;
    padding-top: 28px;
    border-top: var(--card-border);
  }
  .faq-title {
    font-size: 18px;
    color: var(--text);
    margin-bottom: 12px;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .faq-item {
    background: var(--surface);
    border: var(--card-border);
    border-radius: var(--r-card);
    padding: 0 16px;
  }
  .faq-item summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 15px 0;
    cursor: pointer;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-q {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--text);
  }
  .faq-icon {
    font-size: 18px;
    color: var(--meta);
    transition: transform var(--t-fast) ease-out;
  }
  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
  }
  .faq-a {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text);
    margin: 0;
    padding: 0 0 16px;
  }

  .freshness {
    margin: 28px 0 0;
    font-size: 11.5px;
    color: var(--meta);
  }

  @media (min-width: 1024px) {
    .city-hero-inner {
      padding-top: 32px;
    }
    .city-title {
      font-size: 52px;
    }
    .city-intro {
      font-size: 15px;
      max-width: 560px;
    }
    .filmstrip {
      margin-top: 26px;
      gap: 10px;
    }
    .sheet {
      margin-top: -26px;
    }
    .float-search {
      max-width: 880px;
      margin-left: auto;
      margin-right: auto;
    }
    .filter-bar {
      margin: 28px 0 0;
      padding: 0;
      flex-wrap: wrap;
      overflow: visible;
    }
    .filter-bar .chip {
      font-size: 13px;
    }
    .results {
      margin: 20px 0 16px;
    }
    .featured-list,
    .regular-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .regular-grid {
      margin-top: 20px;
    }
  }
</style>
