---
/**
 * Liity mukaan / För studios — BANTAD till ren ansökningssida. Kort intro,
 * en kompakt nivå-teaser (läser namn/priser ur src/data/pricing.ts, delad
 * källa med /hinnasto) som länkar till hela hinnastot, och Netlify-formen.
 * Prisjämförelsen och FAQ:n flyttade till /hinnasto. Sidan är tunn →
 * noindex,follow så /hinnasto är den som rankar (Calles beslut 2026-07-06).
 */
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, localePath, type Locale } from '../../i18n/ui';
import { getCitiesSorted, cityDisplayName } from '../../lib/content';
import { jsonLdString, breadcrumbLd } from '../../lib/schema';
import { liity } from '../../data/liity';
import { pricing, priceLabel, TIER_ORDER, TIER_PRICE } from '../../data/pricing';
import heroImage from '../../assets/bilder/tatuoija-studiossa.png';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const p = (path: string) => localePath(locale, path);
const site = Astro.site!;
const c = liity[locale];
const tiers = pricing[locale].tiers;
const cities = await getCitiesSorted();

const path = '/liity/';
const breadcrumb = breadcrumbLd([
  { name: t('breadcrumb.home'), url: new URL(p('/'), site).href },
  { name: c.h1, url: new URL(p(path), site).href },
]);
---

<BaseLayout
  title={c.metaTitle}
  description={c.metaDescription}
  locale={locale}
  path={path}
  hasAlternate
  noindex
>
  <script type="application/ld+json" set:html={jsonLdString(breadcrumb)} slot="head" />

  <section class="liity-hero">
    <div class="container liity-hero-inner">
      <div class="liity-hero-copy">
        <p class="eyebrow">{c.eyebrow}</p>
        <h1 class="liity-title">{c.h1}</h1>
        <p class="liity-intro">{c.intro}</p>
      </div>
      <div class="liity-hero-media" aria-hidden="true">
        <Image
          src={heroImage}
          alt=""
          widths={[500, 900]}
          sizes="(min-width: 1024px) 40vw, 100vw"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <div class="sheet grain">
    <div class="container sheet-inner">
      <!-- Kompakt nivå-teaser → hela hinnastot (delad pricing-källa) -->
      <a class="teaser" href={p('/hinnasto/')}>
        <div class="teaser-copy">
          <h2 class="teaser-title">{c.teaserTitle}</h2>
          <p class="teaser-text">{c.teaserText}</p>
        </div>
        <div class="teaser-tiers">
          {
            TIER_ORDER.map((tier) => (
              <span class="teaser-tier">
                <span class="teaser-tier-name">{tiers[tier].name}</span>
                <span class="teaser-tier-price">
                  {priceLabel(tier)}
                  {TIER_PRICE[tier] > 0 && <span class="teaser-tier-period">{tiers[tier].period}</span>}
                </span>
              </span>
            ))
          }
        </div>
        <span class="teaser-cta">{c.teaserCta} →</span>
      </a>

      <!-- Ansökningsformulär (Netlify Forms + honeypot) -->
      <section class="form-col" aria-labelledby="liity-form-title" id="ilmoittaudu">
        <h2 class="col-title" id="liity-form-title">{c.formTitle}</h2>
        <form
          class="signup"
          name="liity"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action={p('/liity/')}
        >
          <input type="hidden" name="form-name" value="liity" />
          <p class="hp" aria-hidden="true">
            <label>Bot field <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>
          <div class="form-field">
            <label for="liity-name">{c.form.name}</label>
            <input id="liity-name" name="nimi" type="text" required autocomplete="organization" />
          </div>
          <div class="form-field">
            <label for="liity-city">{c.form.city}</label>
            <div class="select-wrap">
              <select id="liity-city" name="kaupunki" required>
                <option value="" disabled selected>{c.form.cityPlaceholder}</option>
                {cities.map((city) => <option value={city.id}>{cityDisplayName(city, locale)}</option>)}
              </select>
              <span class="caret" aria-hidden="true">▾</span>
            </div>
          </div>
          <div class="form-field">
            <label for="liity-email">{c.form.email}</label>
            <input id="liity-email" name="sahkoposti" type="email" required autocomplete="email" />
          </div>
          <div class="form-field">
            <label for="liity-ig">
              {c.form.instagram} <span class="optional">{c.form.instagramOptional}</span>
            </label>
            <input id="liity-ig" name="instagram" type="text" autocomplete="off" placeholder="@" />
          </div>
          <button class="btn-cta" type="submit">{c.form.submit}</button>
          <p class="form-note">{c.form.note}</p>
        </form>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .liity-hero {
    position: relative;
    z-index: 0;
    background:
      radial-gradient(110% 100% at 80% 0%, rgba(77, 50, 48, 0.2) 0%, rgba(16, 16, 20, 0) 55%),
      var(--ink);
  }
  .liity-hero-inner {
    padding: 28px var(--page-pad) 56px;
  }
  .liity-hero-media {
    margin-top: 22px;
    border-radius: var(--r-card);
    overflow: hidden;
  }
  .liity-hero-media :global(img) {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    filter: saturate(0.9);
  }
  .liity-title {
    font-size: 42px;
    line-height: 1.02;
    color: var(--text-light);
  }
  .liity-intro {
    margin: 12px 0 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--meta);
    max-width: 420px;
  }

  .sheet {
    position: relative;
    z-index: 1;
    background: var(--paper);
    border-radius: var(--r-sheet) var(--r-sheet) 0 0;
    margin-top: -20px;
  }
  .sheet-inner {
    padding: 30px var(--page-pad) 48px;
    max-width: 760px;
    margin-inline: auto;
  }

  /* Nivå-teaser → /hinnasto */
  .teaser {
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: var(--ink);
    border-radius: var(--r-card-lg);
    padding: 22px;
    text-decoration: none;
    transition:
      transform var(--t-med) var(--ease-out),
      box-shadow var(--t-med) var(--ease-out);
  }
  .teaser:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(16, 16, 20, 0.2);
  }
  .teaser-title {
    font-size: 20px;
    color: var(--text-light);
    margin: 0;
  }
  .teaser-text {
    font-size: 13px;
    line-height: 1.55;
    color: var(--meta);
    margin: 6px 0 0;
  }
  .teaser-tiers {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .teaser-tier {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 14px;
    background: rgba(237, 234, 226, 0.06);
    border-radius: var(--r-card);
    min-width: 92px;
  }
  .teaser-tier-name {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--meta);
  }
  .teaser-tier-price {
    font-family: var(--font-display);
    font-size: 17px;
    color: var(--text-light);
  }
  .teaser-tier-period {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--meta);
    margin-left: 2px;
  }
  .teaser-cta {
    font-size: 13px;
    font-weight: 700;
    color: var(--gold);
  }

  /* Formulär */
  .form-col {
    margin-top: 36px;
  }
  .col-title {
    font-size: 22px;
    color: var(--text);
    margin-bottom: 16px;
  }
  .signup {
    background: var(--surface);
    border: var(--card-border);
    border-radius: var(--r-card-lg);
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .hp {
    position: absolute;
    left: -9999px;
    margin: 0;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .form-field label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--meta);
  }
  .optional {
    text-transform: none;
    letter-spacing: 0;
    font-weight: 500;
  }
  .form-field input,
  .form-field select {
    font-family: var(--font-body);
    /* 16px så iOS inte zoomar in vid fokus */
    font-size: 16px;
    color: var(--text);
    background: var(--paper);
    border: var(--card-border-strong);
    border-radius: var(--r-btn);
    padding: 11px 14px;
    width: 100%;
  }
  .form-field input:focus-visible,
  .form-field select:focus-visible {
    outline: 2px solid var(--flash);
    outline-offset: 1px;
  }
  .select-wrap {
    position: relative;
  }
  .select-wrap select {
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
  }
  .caret {
    position: absolute;
    right: 14px;
    top: 50%;
    translate: 0 -50%;
    color: var(--meta);
    font-size: 12px;
    pointer-events: none;
  }
  .form-note {
    font-size: 11.5px;
    color: var(--meta);
    text-align: center;
    margin: 0;
  }

  @media (min-width: 1024px) {
    .liity-hero-inner {
      padding: 44px var(--page-pad) 76px;
      display: grid;
      grid-template-columns: 1.15fr 1fr;
      gap: 48px;
      align-items: center;
    }
    .liity-hero-media {
      margin-top: 0;
      border-radius: var(--r-card-lg);
    }
    .liity-hero-media :global(img) {
      height: 320px;
    }
    .liity-title {
      font-size: 72px;
    }
    .liity-intro {
      font-size: 16px;
      max-width: 520px;
    }
    .sheet {
      margin-top: -26px;
    }
    .sheet-inner {
      padding: 48px var(--page-pad) 72px;
    }
    .teaser {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 28px;
      padding: 28px 32px;
    }
    .teaser-copy {
      flex: 1;
    }
    .form-col {
      margin-top: 48px;
    }
    .col-title {
      font-size: 30px;
      margin-bottom: 20px;
    }
    .signup {
      padding: 24px;
    }
  }
</style>
