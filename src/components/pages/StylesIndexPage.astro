---
/** Stilar-index (/tyylit/) — delad mellan fi och sv. */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, localePath, type Locale } from '../../i18n/ui';
import { getStylesSorted, styleDisplayName } from '../../lib/content';
import { breadcrumbLd } from '../../lib/schema';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const p = (path: string) => localePath(locale, path);
const site = Astro.site!;
const styles = await getStylesSorted();
const title = `${t('nav.styles')} — ${t('site.tagline')} | ${t('site.name')}`;

const ink = (angle: number, from: string, to: string) =>
  `linear-gradient(${angle}deg, ${from} 0%, ${to} 100%)`;
const styleGradients = [
  ink(160, '#1c1c22', '#2f2732'),
  ink(200, '#232029', '#3d2f34'),
  ink(150, '#17171c', '#2b2229'),
  ink(215, '#241f26', '#4d3230'),
  ink(170, '#1e1c26', '#43302f'),
  ink(190, '#211f2b', '#35282b'),
];

const breadcrumb = breadcrumbLd([
  { name: t('breadcrumb.home'), url: new URL(p('/'), site).href },
  { name: t('nav.styles'), url: new URL(p('/tyylit/'), site).href },
]);
---

<BaseLayout
  title={title}
  description={t('site.description')}
  locale={locale}
  path="/tyylit/"
  hasAlternate
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} slot="head" />
  <section class="index-hero">
    <div class="container index-hero-inner">
      <p class="eyebrow">{t('home.styles.eyebrow')}</p>
      <h1 class="index-title">{t('home.styles.title')}</h1>
    </div>
  </section>
  <div class="sheet grain">
    <div class="container sheet-inner">
      <div class="style-grid">
        {
          styles.map((style, index) => (
            <a class="style-card" href={p(`/tyylit/${style.id}/`)}>
              <span
                class="style-bg grain-dark"
                style={`background:${styleGradients[index % styleGradients.length]}`}
                aria-hidden="true"
              />
              <span class="style-name">{styleDisplayName(style, locale)}</span>
              <span class="style-arrow" aria-hidden="true">→</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .index-hero {
    position: relative;
    z-index: 0;
    background: var(--ink);
  }
  .index-hero-inner {
    padding: 28px var(--page-pad) 46px;
  }
  .index-title {
    font-size: 34px;
    line-height: 1.06;
    color: var(--text-light);
  }
  .sheet {
    position: relative;
    z-index: 1;
    background: var(--paper);
    border-radius: var(--r-sheet) var(--r-sheet) 0 0;
    margin-top: var(--sheet-overlap);
  }
  .sheet-inner {
    padding: 24px var(--page-pad) 40px;
  }
  .style-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .style-card {
    position: relative;
    height: 150px;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    isolation: isolate;
  }
  .style-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    transition: transform var(--t-med) var(--ease-out);
  }
  .style-card::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 60%;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(16, 16, 20, 0) 0%, rgba(16, 16, 20, 0.45) 100%);
  }
  .style-name {
    position: absolute;
    left: 14px;
    bottom: 12px;
    z-index: 1;
    font-family: var(--font-display);
    font-size: 17px;
    color: #fff;
    text-shadow: 0 1px 8px rgba(16, 16, 20, 0.5);
    transition: transform var(--t-med) var(--ease-out);
  }
  .style-arrow {
    position: absolute;
    right: 14px;
    bottom: 12px;
    z-index: 1;
    color: var(--text-light);
    font-size: 15px;
    opacity: 0.55;
    transition:
      transform var(--t-med) var(--ease-out),
      opacity var(--t-med) var(--ease-out);
  }
  .style-card:hover .style-bg {
    transform: scale(1.03);
  }
  .style-card:hover .style-name {
    transform: translateY(-4px);
  }
  .style-card:hover .style-arrow {
    opacity: 1;
    transform: translateX(3px);
  }
  @media (min-width: 1024px) {
    .index-hero-inner {
      padding: 44px var(--page-pad) 64px;
    }
    .index-title {
      font-size: 52px;
    }
    .sheet-inner {
      padding: 40px var(--page-pad) 56px;
    }
    .style-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .style-card {
      height: 210px;
      border-radius: var(--r-card);
    }
    .style-name {
      left: 18px;
      bottom: 15px;
      font-size: 22px;
    }
    .style-arrow {
      right: 18px;
      bottom: 15px;
      font-size: 17px;
    }
  }
</style>
