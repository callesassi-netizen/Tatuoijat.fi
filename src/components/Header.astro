---
import Logo from './Logo.astro';
import { useTranslations, localePath, type Locale } from '../i18n/ui';
import { citiesIndexPath } from '../lib/routes';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const p = (path: string) => localePath(locale, path);

// Markera aktiv sektion i navigationen
const currentPath = Astro.url.pathname;
const isActive = (prefix: string) => currentPath.startsWith(p(prefix));

const citiesBase = citiesIndexPath(locale);
const navLinks = [
  { href: p(citiesBase), label: t('nav.cities'), active: isActive(citiesBase) },
  { href: p('/tyylit/'), label: t('nav.styles'), active: isActive('/tyylit') },
  // Prisguiden /hinnat (konsument-SEO) — visas i BÅDE desktop- och mobilnav.
  { href: p('/hinnat/'), label: t('nav.prices'), active: isActive('/hinnat') },
];
// "Studioille"-navet pekar på säljsidan /hinnasto (ansökningsformen /liity
// nås därifrån). Aktiv på båda B2B-sidorna.
const studioActive = isActive('/hinnasto') || isActive('/liity');
---

<header class="site-header">
  <div class="container header-inner">
    <details class="mobile-menu">
      <summary aria-label={t('nav.menu')}>
        <span class="burger" aria-hidden="true"><i></i><i></i><i></i></span>
      </summary>
      <nav class="mobile-panel">
        {
          navLinks.map((link) => (
            <a href={link.href} aria-current={link.active ? 'page' : undefined}>
              {link.label}
            </a>
          ))
        }
        <a href={p('/hinnasto/')} aria-current={studioActive ? 'page' : undefined}>
          {t('nav.forStudios')}
        </a>
      </nav>
    </details>

    <a class="home-link" href={p('/')}>
      <Logo locale={locale} />
      <span class="visually-hidden">{t('site.tagline')}</span>
    </a>

    <a class="search-link" href={p('/') + '#haku'} aria-label={t('nav.toSearch')}>
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.6"></circle>
        <path d="M12.5 12.5L16 16" stroke="currentColor" stroke-width="1.6"></path>
      </svg>
    </a>

    <nav class="desktop-nav" aria-label={t('nav.menu')}>
      {
        navLinks.map((link) => (
          <a class="ink-link" href={link.href} aria-current={link.active ? 'page' : undefined}>
            {link.label}
          </a>
        ))
      }
      <a class="pill" href={p('/hinnasto/')} aria-current={studioActive ? 'page' : undefined}>
        {t('nav.forStudios')}
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--ink);
    color: var(--text-light);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px var(--page-pad);
  }
  .home-link {
    text-decoration: none;
  }

  /* Mobil: hamburgare vänster, logo mitten, sökikon höger */
  .mobile-menu {
    position: relative;
  }
  .mobile-menu summary {
    list-style: none;
    display: flex;
    align-items: center;
    padding: 6px;
    margin: -6px;
    cursor: pointer;
  }
  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }
  .burger {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 20px;
  }
  .burger i {
    height: 2px;
    background: var(--text-light);
  }
  .burger i:last-child {
    width: 14px;
  }
  .mobile-panel {
    position: absolute;
    z-index: 20;
    top: calc(100% + 14px);
    left: calc(-1 * var(--page-pad) + 8px);
    min-width: 220px;
    display: flex;
    flex-direction: column;
    background: var(--ink);
    border: var(--hairline-dark);
    border-radius: var(--r-card);
    padding: 8px;
  }
  .mobile-panel a {
    color: var(--text-light);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    padding: 11px 14px;
    border-radius: 8px;
  }
  .mobile-panel a:hover {
    background: rgba(237, 234, 226, 0.08);
  }
  .mobile-panel a[aria-current='page'] {
    background: rgba(237, 234, 226, 0.1);
    font-weight: 700;
  }
  .search-link {
    color: var(--text-light);
    padding: 6px;
    margin: -6px;
  }

  .desktop-nav {
    display: none;
  }

  @media (min-width: 1024px) {
    .header-inner {
      padding-top: 18px;
      padding-bottom: 18px;
    }
    .mobile-menu,
    .search-link {
      display: none;
    }
    .desktop-nav {
      display: flex;
      align-items: center;
      gap: 28px;
    }
    .desktop-nav a {
      color: var(--text-light);
      text-decoration: none;
      font-size: 13.5px;
      font-weight: 500;
    }
    .desktop-nav .pill {
      font-size: 12.5px;
      font-weight: 600;
      border: 1px solid rgba(237, 234, 226, 0.35);
      border-radius: var(--r-chip);
      padding: 8px 16px;
      transition:
        background-color var(--t-fast) ease-out,
        color var(--t-fast) ease-out;
    }
    .desktop-nav .pill:hover {
      background: var(--text-light);
      color: var(--ink);
    }
    /* Aktiv sida: permanent bläck-underline; Liity = ljus fylld pill (wireframe 3f) */
    .desktop-nav a[aria-current='page']:not(.pill)::after {
      transform: scaleX(1);
    }
    .desktop-nav .pill[aria-current='page'] {
      background: var(--text-light);
      border-color: var(--text-light);
      color: var(--ink);
    }
  }
</style>
