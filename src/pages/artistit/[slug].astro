---
import { getCollection } from 'astro:content';
import ArtistPage from '../../components/pages/ArtistPage.astro';

export async function getStaticPaths() {
  const studios = await getCollection('studios');
  return studios.map((studio) => ({ params: { slug: studio.id }, props: { studio } }));
}

const { studio } = Astro.props;
---

<ArtistPage studio={studio} locale="fi" />
