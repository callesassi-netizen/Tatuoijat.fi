---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { useTranslations, localePath, defaultLocale, type Locale } from '../i18n/ui';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  /**
   * Path utan locale-prefix (t.ex. "/tatuoijat/helsinki/"). Används för
   * canonical + hreflang. Sätt hasAlternate=false för sidor som (ännu)
   * saknar version på det andra språket — då skrivs ingen hreflang ut.
   */
  path: string;
  hasAlternate?: boolean;
  /** Dölj header/footer (används ej normalt). */
  bare?: boolean;
}

const {
  title,
  description,
  locale = defaultLocale,
  path,
  hasAlternate = false,
  bare = false,
} = Astro.props;

const t = useTranslations(locale);
const site = Astro.site!;
const canonical = new URL(localePath(locale, path), site);
const altFi = new URL(localePath('fi', path), site);
const altSv = new URL(localePath('sv', path), site);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {
      hasAlternate && (
        <>
          <link rel="alternate" hreflang="fi" href={altFi} />
          <link rel="alternate" hreflang="sv" href={altSv} />
          <link rel="alternate" hreflang="x-default" href={altFi} />
        </>
      )
    }
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="preload"
      href="/fonts/archivo-black-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={t('site.name')} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="generator" content={Astro.generator} />
    <slot name="head" />
  </head>
  <body>
    {!bare && <Header locale={locale} />}
    <main id="main">
      <slot />
    </main>
    {!bare && <Footer locale={locale} switchPath={path} />}
  </body>
</html>
