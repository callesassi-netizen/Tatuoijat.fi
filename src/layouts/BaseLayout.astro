---
import { getImage } from 'astro:assets';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { useTranslations, localePath, defaultLocale, type Locale } from '../i18n/ui';
import ogSource from '../assets/bilder/hero-tatuoija.png';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  /**
   * Path utan locale-prefix (t.ex. "/tatuoijat/helsinki/"). Används för
   * canonical + hreflang. Sätt hasAlternate=false för sidor som (ännu)
   * saknar version på det andra språket — då skrivs ingen hreflang ut.
   */
  path: string;
  hasAlternate?: boolean;
  /**
   * noindex,follow — tunna sidor (t.ex. städer under CITY_INDEX_MIN_STUDIOS)
   * hålls utanför index men länkjuicen flödar vidare. Sitemap-filtret i
   * astro.config.mjs måste utesluta samma sidor.
   */
  noindex?: boolean;
  /** Dölj header/footer (används ej normalt). */
  bare?: boolean;
}

const {
  title,
  description,
  locale = defaultLocale,
  path,
  hasAlternate = false,
  noindex = false,
  bare = false,
} = Astro.props;

const t = useTranslations(locale);
const site = Astro.site!;
const canonical = new URL(localePath(locale, path), site);
const altFi = new URL(localePath('fi', path), site);
const altSv = new URL(localePath('sv', path), site);

// Sajtgemensam OG-bild (egen miljöbild, Bildpolicy §4) — JPEG för
// bästa kompatibilitet med delnings-skrapor
const ogImage = await getImage({
  src: ogSource,
  width: 1200,
  height: 630,
  fit: 'cover',
  format: 'jpeg',
});
const ogImageUrl = new URL(ogImage.src, site);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonical} />
    {
      hasAlternate && (
        <>
          <link rel="alternate" hreflang="fi" href={altFi} />
          <link rel="alternate" hreflang="sv" href={altSv} />
          <link rel="alternate" hreflang="x-default" href={altFi} />
        </>
      )
    }
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="preload"
      href="/fonts/archivo-black-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={t('site.name')} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">{t('a11y.skipToContent')}</a>
    {!bare && <Header locale={locale} />}
    <main id="main">
      <slot />
    </main>
    {!bare && <Footer locale={locale} switchPath={path} />}
  </body>
</html>
